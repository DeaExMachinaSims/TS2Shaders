#---------------------------------------------------------------------------
# Old shaders
# These are kept in this file for compatibility following a name
# change on 30Mar02.  The new names are "Phong", "PhongTexture", etc.
# Leo 25Apr02 -- Since these are deprecated, removed #beginshader comments
#---------------------------------------------------------------------------

define DiffuseMaterial()  #referenced from Go2SCO and *.ma files
  material
     create PhongShaders()
  end
enddef
define DiffuseAlphaMaterial()   #referenced from Go2SCO only
  material
     create PhongAlphaShaders()
  end
enddef
define BaseTextureMaterial() #referenced from .ma files
   create PhongTexture()
enddef
define BaseTextureAlphaMaterial()  #referenced from Go2SCO and *.ma files
  material
     create PhongTextureAlphaShaders()
  end
enddef


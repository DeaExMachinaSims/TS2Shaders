# --- PhongTextureCubeMapIlluminationShaders -------------------------------------------------------------------------
define PhongTextureCubeMapIllumination()
   material
      create PhongTextureCubeMapIlluminationShaders()
   end
enddef

define PhongTextureCubeMapIlluminationShaders()
   setb stdMatBaseTextureEnabled true
   setb stdMatSpecMaskTextureEnabled  false
   setb stdMatNormalMapTextureEnabled false
   set stdMatEnvCubeMode diffuseRadiance
   set stdMatEnvCubeBlurFactor $blurFactor
   set stdMatEnvCubeCoef ($reflectivity,$reflectivity,$reflectivity)
   set  stdMatDiffCoef   ($stdMatDiffCoef * ($deprecatedStdMatInvDiffuseCoeffMultiplier).xxx)
   create StandardShaders()
enddef

define CubeMapReflection()
   material
      shader -layer ($stdMatLayer * 18)
         vertexFormatPred position 0 true
         vertexFormatPred normal   0 true
         vertexFormatPred blendindices  0 false
         vertexFormatPred targetindices 0 false

         pass -fixedFunction
            create LightingStatesNoStdLightsParam(true true)

            colorScalar $stdMatSpecCoef
            fillmode $stdMatFillMode

            stage
               texture $stdMatEnvCubeTextureName
               textureMIPFilterHint linear $blurFactor

               ffTextureCoordsSource fromReflectionVector
               textureTransformType vector3
               ffTextureMatrix -orientCameraToGlobal

               textureAddressing clamp clamp clamp

               textureBlend multiply(texture colorScalar) select(colorScalar)
            end
         end
      end
   end
enddef


setf playSpeed 10

setf playSpeed 15
setf resFactor 16
setf tileCountU 16
setf tileCountV 1
define AnimatedTexture()
  material
     shader
         vertexFormatPred blendindices  0 false
         vertexFormatPred targetindices 0 false

        pass -fixedFunction -modifiedEachFrameHint
           create LightingStatesNoStdLights()
           fillmode $stdMatFillMode
           stage
              texture $stdMatBaseTextureName ${stdMatBaseTextureParam}
              textureTileAnimation $playSpeed -tiles ($tileCountU, $tileCountV) -targetType fixedFunction
              textureBlend select(texture) select(texture)
           end
        end
     end
  end
enddef


setf playSpeed 15
setf resFactor 16
setf tileCountU 16
setf tileCountV 1
define AnimatedTextureAlpha()
  material
     shader -layer ($stdMatLayer * 18 + 17)
         vertexFormatPred blendindices  0 false
         vertexFormatPred targetindices 0 false
        pass -fixedFunction  -modifiedEachFrameHint
           create LightingStatesNoStdLights()
           alphaBlend srcFactor(srcAlpha) add dstFactor(one)
           depthTest true -enableDepthWrite false
           fillmode $stdMatFillMode
           
           stage
              texture $stdMatBaseTextureName ${stdMatBaseTextureParam}
              textureTileAnimation $playSpeed -tiles ($tileCountU, $tileCountV) -targetType fixedFunction
              textureBlend select(texture) select(texture)
           end
        end
     end
  end
enddef


seti defaultLayer  0
seti defaultAlphaLayer 17
seti defaultTranslucentLayer 17


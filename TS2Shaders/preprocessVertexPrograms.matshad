
enableSoftwareVertexPrograms

define PreprocessVertexShader()


	
	create SetupCommonHWShaderVariablesAndPredicates()
	setb ubyte4Supported true

   # sniff test 'single layer face fix'
   create TestForEyeMotion()

	outVertexFormat vector3f position
	outVertexFormat vector3f normal
	
	if ($hasTexcoords)
		outVertexFormat vector2f texcoord
	endif
   
	shaderProgram -preprocess -method link
	#	define TransformFragments(skinFlag singleBone swvsFlag morphFlag positionMorphCount normalMorphCount normalFlag shaderVersion)

		# SWVP true = unpacked transforms.
		create TransformFragments($doSkinning $stdMatReduceBoneWeights true $doMorphing $numPosMorphs $numNormMorphs true 3_0)
		
		if ($eyeMotion)
			shaderFragment EyeShifterTexGen3_0
		else
         if ($hasTexcoords)
            shaderFragment NoTextureMagic3_0
         endif
		endif
				
		create BindsForSoftwareVSTransforms($doSkinning $doMorphing)
   
      if ($eyeMotion)
         bindConstants 11 -bindingID immediateData -data @eyeDirection -constantType float
         bindConstants 11 -bindingID immediateData -data @l_eyeStretch -constantType float -startChannel Z
         bindConstants 11 -bindingID immediateData -data @r_eyeStretch -constantType float -startChannel W
      endif
   
	end
	
	
enddef




define PreprocessVertexShaderOldSchool()


	if (hasVertexFormat(texcoord, 1) = false)
		setb eyeGizmoEnable false
	endif

	if (varExists(eyeGizmoEnable) = false)
		setb eyeGizmoEnable false
	endif

   if ($doSkinning and $doMorphing)
      if ($stdMatMorphState)
         create PreprocessSkinningAndMorphTargets()
      else
         create PreprocessSkinning()
      endif
   elseif ($doSkinning and not $doMorphing)
      create PreprocessSkinning()
   elseif (not $doSkinning and $doMorphing)
      create PreprocessMorphTargets()
   endif
enddef


# v0  position
# v1  normal
# v2  texcoord
# v3  tangent
# v4  binormal
# v5  blendindices
# v6  blendweights
# v7  targetindices
# v8  positiondelta0
# v9  positiondelta1
# v10 positiondelta2
# v11 positiondelta3
# v12 normaldelta0
# v13 normaldelta1
# v14 normaldelta2
# v15 normaldelta3

# changed so that morph weights are are always at 3-32, and poses are always at 33+



define PreprocessMorphTargets()
   vertexFormatPred position      0 true
   vertexFormatPred normal        0 true
   if (hasVertexFormat(texcoord, 0))
      vertexFormatPred texcoord 0 true
   endif
   vertexFormatPred targetindices 0 true
   vertexFormatPred positiondelta (0, vertexFormatRange(positiondelta) + 1) true
   vertexFormatPred normaldelta   (0, vertexFormatRange(normaldelta)   + 1) true

   outVertexFormat vector3f position
   outVertexFormat vector3f normal
   if (hasVertexFormat(texcoord, 0))
      outVertexFormat vector2f texcoord
   endif

   numMorphTargetsPred numMorphTargets -upperBound

   seti numPosMorphs  (vertexFormatRange(positiondelta) + 1)
   seti numNormMorphs (vertexFormatRange(normaldelta)   + 1)


	
	shaderProgram -preprocess
	
	if ($eyeGizmoEnable)
		bindConstants 2 -bindingID immediateData -data @eyeAnimation -constantType float
	endif

	bindConstants 3 -bindingID morphWeights -constantCount 30 -constantType float

	shaderSource
		vs_3_0
		dcl_position	 v0
		dcl_normal		 v1
		dcl_targetindices	 v7
		dcl_position4	v8
		dcl_position5	v9
		dcl_position6	v10
		dcl_position7	v11	  
		dcl_normal4		v12
		dcl_normal5		v13
		dcl_normal6		v14
		dcl_normal7		v15
		
		dcl_position o0
		dcl_normal   o1
      
	endShaderSource
      
	if (hasVertexFormat(texcoord, 0))
		shaderSource "dcl_texcoord0 v2"
		shaderSource "dcl_texcoord0 o2"
	endif
	
	if (hasVertexFormat(texcoord, 1))
		shaderSource "dcl_texcoord1 v3"
	endif

	shaderSource "mova a0, v7"
      
	   
    create MorphPositionAssembly(${numPosMorphs})
    create MorphNormalsAssembly(${numNormMorphs})

	shaderSource
		  mov o0, r0
	      mov o1, r1
	endShaderSource
      
	if (hasVertexFormat(texcoord, 0))
				
		if ($eyeGizmoEnable = false)		
			shaderSource "mov o2.xy, v2.xy"
		else
			shaderSource 
				mul r2.xy, v3.xx, c2
            mov r2.y, -r2.yy
				add r2.xy, r2, v2
				mov o2.xy, r2
			endShaderSource
		endif
		
	endif
		
   end
enddef


define PreprocessSkinning()
   vertexFormatPred position      0 true
   vertexFormatPred normal        0 true
   if (hasVertexFormat(texcoord, 0))
      vertexFormatPred texcoord 0 true
   endif
   vertexFormatPred blendindices 0 true
   vertexFormatPred blendweights 0 true

   outVertexFormat vector3f position
   outVertexFormat vector3f normal
   if (hasVertexFormat(texcoord, 0))
      outVertexFormat vector2f texcoord
   endif

   numPoseTransformsPred numPoseTransforms -upperBound

	shaderProgram -preprocess

		if ($eyeGizmoEnable)
			bindConstants 2 -bindingID immediateData -data @eyeAnimation -constantType float
		endif
		
		bindConstants 33 -bindingID posesToCamera -constantCount 240 -constantType float

		shaderSource
	  
			vs_3_0

			dcl_position     v0
			dcl_normal       v1
			dcl_blendindices v5
			dcl_blendweights v6
		endShaderSource

   		if (hasVertexFormat(texcoord, 1))
			shaderSource "dcl_texcoord1 v3"
		endif
		
		shaderSource
			dcl_position     o0
			dcl_normal       o1
		endShaderSource
      
		if (hasVertexFormat(texcoord, 0))
			shaderSource "dcl_texcoord0 v2"
			shaderSource "dcl_texcoord0 o2"
		endif
		
				
		shaderSource
	  
			def c0, 3, 1, 255, -1

      ; multiply bone indices by 3 to obtain constant register offsets for the pose transforms in a0
			mul  r2, v5, c0.xxxx
			mova a0, r2
			mov r0, v0
			mov r1, v1
			
		endShaderSource
	  
		create SkinPositionAssembly()

      # transform the normal
      # r5 is starting index of register having composed matrix computed in SkinPosAsm
		shaderSource "m3x3 o1.xyz, r1, r5"

      if (hasVertexFormat(texcoord, 0))
			if ($eyeGizmoEnable = false)		
				shaderSource "mov o2.xy, v2.xy"
			else
				shaderSource 
					mul r2.xy, v3.xx, c2
               mov r2.y, -r2.yy
					add r2.xy, r2, v2
					mov o2.xy, r2
				endShaderSource
			endif
      endif
   end
enddef


define PreprocessSkinningAndMorphTargets()
   vertexFormatPred position      0 true
   vertexFormatPred normal        0 true
   if (hasVertexFormat(texcoord, 0))
      vertexFormatPred texcoord 0 true
   endif
   vertexFormatPred blendindices 0 true
   vertexFormatPred blendweights 0 true
   vertexFormatPred targetindices 0 true
   vertexFormatPred positiondelta (0, vertexFormatRange(positiondelta) + 1) true
   vertexFormatPred normaldelta   (0, vertexFormatRange(normaldelta)   + 1) true

   outVertexFormat vector3f position
   outVertexFormat vector3f normal
   if (hasVertexFormat(texcoord, 0))
      outVertexFormat vector2f texcoord
   endif

   if (hasVertexFormat(texcoord, 1))
      vertexFormatPred texcoord 1 true
   else
        vertexFormatPred texcoord 1 false
   endif

   numMorphTargetsPred   numMorphTargets
   numPoseTransformsPred numPoseTransforms -upperBound

   seti numPosMorphs  (vertexFormatRange(positiondelta) + 1)
   seti numNormMorphs (vertexFormatRange(normaldelta)   + 1)

   shaderProgram -preprocess

      bindConstants 33 -bindingID posesToCamera -constantCount 240
	  bindConstants 3 -bindingID morphWeights -constantCount 30
	  
		if ($eyeGizmoEnable)
			bindConstants 2 -bindingID immediateData -data @eyeAnimation -constantType float
		endif	
		
		shaderSource
			vs_3_0

			dcl_position     v0
			dcl_normal       v1
			dcl_blendindices v5
			dcl_blendweights v6
			dcl_targetindices  v7
			dcl_position4 v8
			dcl_position5 v9
			dcl_position6 v10
			dcl_position7 v11    
			dcl_normal4 v12
			dcl_normal5 v13
			dcl_normal6 v14
			dcl_normal7 v15

			dcl_position     o0
			dcl_normal       o1
		endShaderSource
		
		if (hasVertexFormat(texcoord, 0))
			shaderSource "dcl_texcoord0 v2"
			shaderSource "dcl_texcoord0 o2"
		endif
		
		if (hasVertexFormat(texcoord, 1))
			shaderSource "dcl_texcoord1 v3"
		endif

		shaderSource "def c0, 3,1,255, -1"

		shaderSource "mova a0, v7"
      
		create MorphPositionAssembly(${numPosMorphs})
		create MorphNormalsAssembly(${numNormMorphs})

		# multiply bone indices by 3 to obtain constant register offsets for the pose transforms in a0
		
		shaderSource 
			
			mul  r2, v5, c0.xxxx
			mova a0, r2
			
		endShaderSource
		
		create SkinPositionAssembly()

		# transform the normal
		# r5 is starting index of register having composed matrix computed in SkinPosAsm
		shaderSource "m3x3 o1.xyz, r1, r5"

		if (hasVertexFormat(texcoord, 0))
			if ($eyeGizmoEnable = false)		
				shaderSource "mov o2.xy, v2.xy"
			else
				shaderSource 
					mul r2.xy, v3.xx, c2
               mov r2.y, -r2.y
					add r2.xy, r2, v2
					mov o2.xy, r2
				endShaderSource
			endif
		endif
	end
enddef




#
# Skinning
#
define SkinPositionAssembly()


   # This case is for shadows, which don't need skin blending
   # pos' = pos * M[idx0] * w0
   if ($stdMatReduceBoneWeights)
      shaderSource 
		mov r5, c33[a0.x]
        mov r6, c34[a0.x]
		mov r7, c35[a0.x]
		mov r0.w, c0.y

		m4x3 r2.xyz, r0, c33[a0.x]
	  endShaderSource
   endif


   if (not $stdMatReduceBoneWeights)
      # compute M' = w0 * M[idx0] + w1 * M[idx1] + w2* M[idx2] + (1 - w0 - w1 - w2) * M[idx3]
      # M' = w0 * M[idx0]
      
      shaderSource 
		mul r5, c33[a0.x], v6.xxxx
		mul r6, c34[a0.x], v6.xxxx
		mul r7, c35[a0.x], v6.xxxx

		setp_ne p0, v5, c0.zzzz
		
		; Intel says predication is 'fast', so use it here.
		if p0.y
      
			; M' += w1 * M[idx1]
         mad r5, c33[a0.y], v6.yyyy, r5
         mad r6, c34[a0.y], v6.yyyy, r6
         mad r7, c35[a0.y], v6.yyyy, r7

         if p0.z
            ;M' += w2 * M[idx2]
            mad r5, c33[a0.z], v6.zzzz, r5
            mad r6, c34[a0.z], v6.zzzz, r6
            mad r7, c35[a0.z], v6.zzzz, r7

            if p0.w
               ; M' += (1 - w0 - w1 - w2) * M[idx2]

               ; the last weight is calculated as 1 - w0 - w1 - w2
               ; which can be done with a single DP4 (-1 * x + -1*y + -1*z + 1*1)
               dp4 r8.x, v6, c0.wwwy
			   mad r5, c33[a0.w], r8.xxxx, r5
               mad r6, c34[a0.w], r8.xxxx, r6
               mad r7, c35[a0.w], r8.xxxx, r7
               
            endif
         endif
      endif
      

      # compute pos' = pos * M'
      dp4 r2.x, r0, r5
      dp4 r2.y, r0, r6
      dp4 r2.z, r0, r7
     
      mov r2.w, c0.y
      endShaderSource
   endif

   shaderSource "mov o0, r2"
enddef


#
# Morph targets
#

define MorphPositionAssembly(range)
   create MorphPositionAssembly&{range}()
enddef

define MorphPositionAssembly0()
   shaderSource "mov r0, v0"
enddef

define MorphPositionAssembly1()
   shaderSource "mov r0, v0"
   shaderSource "mad r0.xyz, v8.xyz, c3[a0.x].xxx, r0.xyz"
enddef

define MorphPositionAssembly2()
   shaderSource "mov r0, v0"
   shaderSource "mad r0.xyz, v8.xyz, c3[a0.x].xxx, r0.xyz"
   shaderSource "mad r0.xyz, v9.xyz, c3[a0.y].xxx, r0.xyz"
enddef

define MorphPositionAssembly3()
   shaderSource "mov r0, v0"
   shaderSource "mad r0.xyz, v8.xyz, c3[a0.x].xxx, r0.xyz"
   shaderSource "mad r0.xyz, v9.xyz, c3[a0.y].xxx, r0.xyz"
   shaderSource "mad r0.xyz, v10.xyz, c3[a0.z].xxx, r0.xyz"
enddef

define MorphPositionAssembly4()
   shaderSource "mov r0, v0"
   shaderSource "mad r0.xyz, v8.xyz, c3[a0.x].xxx, r0.xyz"
   shaderSource "mad r0.xyz, v9.xyz, c3[a0.y].xxx, r0.xyz"
   shaderSource "mad r0.xyz, v10.xyz, c3[a0.z].xxx, r0.xyz"
   shaderSource "mad r0.xyz, v11.xyz, c3[a0.w].xxx, r0.xyz"
enddef



define MorphNormalsAssembly(range)
   create MorphNormalsAssembly&{range}()
enddef

define MorphNormalsAssembly0()
   shaderSource "mov r1, v1"
enddef

define MorphNormalsAssembly1()
   shaderSource "mov r1, v1"
   shaderSource "mad r1.xyz, v12.xyz, c3[a0.x].xxx, r1.xyz"
enddef

define MorphNormalsAssembly2()
   shaderSource "mov r1, v1"
   shaderSource "mad r1.xyz, v12.xyz, c3[a0.x].xxx, r1.xyz"
   shaderSource "mad r1.xyz, v13.xyz, c3[a0.y].xxx, r1.xyz"
enddef

define MorphNormalsAssembly3()
   shaderSource "mov r1, v1"
   shaderSource "mad r1.xyz, v12.xyz, c3[a0.x].xxx, r1.xyz"
   shaderSource "mad r1.xyz, v13.xyz, c3[a0.y].xxx, r1.xyz"
   shaderSource "mad r1.xyz, v14.xyz, c3[a0.z].xxx, r1.xyz"
enddef

define MorphNormalsAssembly4()
   shaderSource "mov r1, v1"
   shaderSource "mad r1.xyz, v12.xyz, c3[a0.x].xxx, r1.xyz"
   shaderSource "mad r1.xyz, v13.xyz, c3[a0.y].xxx, r1.xyz"
   shaderSource "mad r1.xyz, v14.xyz, c3[a0.z].xxx, r1.xyz"
   shaderSource "mad r1.xyz, v15.xyz, c3[a0.w].xxx, r1.xyz"
enddef


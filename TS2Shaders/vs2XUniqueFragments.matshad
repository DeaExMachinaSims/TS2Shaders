
#include vs2XUniqueFragments.matShad

# for lighting modes

seti kNoLighting 0
seti kAmbientOnly 1
seti kFullLighting 2
setb kUseShaderPrograms true
setb kUsePS30 true
setb kRaiseLightSnowFF false

setb kForceNoDX9 false
setb kForceNoDX8 false
setb kForceNoDX7 false

#enableShaderProgramDebugging -vertex


# these files will contain sub-sections for VS2, VS2x, VS1

include vsLightFragments.matShad
include vsTransformFragments.matShad
include vsPixelLightingFragments.matShad




define VSSharedFragments(versionString)


shaderSource


//#######################################
//#   TEXGEN AND TEXTURE TRANSFORMS     #
//#######################################


vertexfragment TexgenTransformedReflectionVector&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mov r_temp11.w, c_helperConstant1.z
	
	m3x3 oT1.xyz, r_reflectionVector.xyz, c_cubemapMatrix
	
};

vertexfragment TexgenTransformedCameraNormal&{versionString} =
asm_fragment
{
	vs_&{versionString}
	mov r_temp9.w, c_helperConstant1.z

	m3x3 oT1.xyz, r_temp9, c_cubemapMatrix
	
};


vertexfragment TexgenTransformedNormal&{versionString} =
asm_fragment
{
	vs_&{versionString}

	m3x3 oT1.xyz, v_NORMAL, c_cubemapMatrix
	
};



vertexfragment TexgenReflectionVector&{versionString} =
asm_fragment
{
	vs_&{versionString}

   mov oT1.xyz, r_reflectionVector
	
};


vertexfragment TexgenReflectionVectorTex2&{versionString} =
asm_fragment
{
	vs_&{versionString}
	
	dp3 oT2.x, r_reflectionVector, c_cubemapMatrix[0]
	dp3 oT2.y, r_reflectionVector, c_cubemapMatrix[1]
	dp3 oT2.z, r_reflectionVector, c_cubemapMatrix[2]

};


vertexfragment TexgenCameraNormal&{versionString} =
asm_fragment
{
	vs_&{versionString}
	mov oT1.xyz, r_temp9
};



vertexfragment TerrainStraddleTexgen&{versionString} =
asm_fragment
{
	vs_&{versionString}
	
	mul oT0.xy, c_textureMatrix[0], v_POSITION.zw
	
	
};

vertexfragment TerrainUnderwaterGradientTexGenUVZero&{versionString} =
asm_fragment
{
	vs_&{versionString}

	// scales the height, then shifts it so the gradient texture can be applied to the underwater terrain
	mad oT0.xy, c_textureMatrix[0].xx, v_POSITION.zz, c_textureMatrix[0].yy

};


vertexfragment TerrainWaterMaskTexGenUVZero&{versionString} =
asm_fragment
{
	vs_&{versionString}

	// transforms terrain height so that 0.5 lands on the water height
	mad oT0.xy, c_textureMatrix[0].zz, v_POSITION.zz, c_textureMatrix[0].ww

};



vertexfragment TerrainWaterMaskTexGenUVOne&{versionString} =
asm_fragment
{
	vs_&{versionString}

	// transforms terrain height so that 0.5 lands on the water height
	mad oT1.xy, c_textureMatrix[0].zz, v_POSITION.zz, c_textureMatrix[0].ww

};





vertexfragment TerrainPaintTexGen&{versionString} =
asm_fragment
{
	vs_&{versionString}


	mul oT0.xy, c_textureMatrix[0].zwzw, v_TEXCOORD
	mul oT1.xy, c_textureMatrix[0], v_TEXCOORD
	
};



vertexfragment TerrainUnderwaterTexgen&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mad oT0.xy, c_textureMatrix[0].zz, v_POSITION.zz, c_textureMatrix[0].ww
	
};


vertexfragment TerrainLightmapTexgenUVOne&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mul oT1.xy, c_textureMatrix[0].zw, v_POSITION.xy	
	
};


vertexfragment TextureScaleUVZero&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mul oT0.xy, c_textureMatrix[0].xy, v_TEXCOORD
	
};

vertexfragment TextureScaleUVOne&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mul oT1.xy, c_textureMatrix[0].xy, v_TEXCOORD
	
};


vertexfragment TexgenNormalVector&{versionString} =
asm_fragment
{
	vs_&{versionString}
	mov oT1.xyz, v_NORMAL
};


vertexfragment Transform2DTexcoords&{versionString} =
asm_fragment
{
	vs_&{versionString}

	dp4 oT0.x, v_TEXCOORD, c_textureMatrix[0]
	dp4 oT0.y, v_TEXCOORD, c_textureMatrix[1]
	
};


vertexfragment TexgenBumpMapReflectionCube&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mov oT0.xy, v_TEXCOORD
	
	// move tangent space matrix into the PS
	mov oT1.xyz, r_tangent
	mov oT2.xyz, r_binormal
	mov oT3.xyz, r_temp9

	// create viewVector
	dp3 r_temp1.w, -r_temp8, -r_temp8
	rsq r_temp1.w, r_temp1.w
	mul r_viewVector.xyz, -r_temp8, r_temp1.w

	// supply view vector to texm3x3vspec
	mov oT1.w, r_viewVector.x
	mov oT2.w, r_viewVector.y
	mov oT3.w, r_viewVector.z


};




vertexfragment Copy2DTexcoords&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mov oT0.xy, v_TEXCOORD
	
};





vertexfragment Copy2DTexcoordsToTexOne&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mov oT1.xy, v_TEXCOORD
	
};

vertexfragment Copy2DTexcoordsToTexTwo&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mov oT2.xy, v_TEXCOORD
	
};



// for a 4-way blending, or other use.
vertexfragment Copy2DTexcoordsToAllSamplers&{versionString} =
asm_fragment
{
	vs_&{versionString}

	mov oT0.xy, v_TEXCOORD
	mov oT1.xy, v_TEXCOORD
	mov oT2.xy, v_TEXCOORD
	mov oT3.xy, v_TEXCOORD

};



vertexfragment CelShadingParticlePreScale&{versionString} = 
asm_fragment
{
	vs_&{versionString}

   mul r_temp10, r_temp10, c_textureMatrix[1].z   // this is the animated 'particle scale' factor.

};




vertexfragment CelShadingOutlinePosition&{versionString} = 
asm_fragment
{
	vs_&{versionString}

   // multiply normal by a scalar, this is the offset factor
   
   mad r_position.xyz, c_textureMatrix[0].x, r_temp9, r_position   // texmat 0 has outline amount in it.
   mov r_position.w, c_basics.z
   
   
	m4x4 r_clipSpace, r_position, c_cameraToClipSpaceMatrix
   
   mov oPos.xyw, r_clipSpace
   
   // push Z back into the screen a bit.  =  Z' = W * offset + Z
   
   mad oPos.z, r_clipSpace.w, c_textureMatrix[0].z, r_clipSpace.z // texmat0.z = 0.0005
      
};





vertexfragment CelShadingOutlinePositionParticle&{versionString} = 
asm_fragment
{
	vs_&{versionString}

   // multiply normal by a scalar, this is the offset factor
   
   mad r_position.xyz, c_textureMatrix[2].z, r_temp9, r_position
   mov r_position.w, c_basics.z

	m4x4 r_clipSpace, r_position, c_cameraToClipSpaceMatrix
   
   mov oPos.xyw, r_clipSpace
   
   // push Z back into the screen a bit.  =  Z' = W * offset + Z
   
   mad oPos.z, r_clipSpace.w, c_textureMatrix[0].z, r_clipSpace.z
      
};


vertexfragment CelShadingDiffuse&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	// complete writing position.
	m4x4 oPos, r_position, c_cameraToClipSpaceMatrix
	
    dp3 oT0.xz, c_lightDirections[0], r_temp9
  // instead of clamping, the texture addressing can take care of that.
     // and it actually results in proper 'signed lighting' by interpolating negative texcoords.
     
};


// so, the alpha (0-1) is pushed into the V channel of the texture lookup
// U = N.L
// V = "Color".  Multiple ramps can be selected across the object for example

vertexfragment CelShadingVertexAlphaSelectsColor&{versionString} = 
asm_fragment
{
	vs_&{versionString}

   mov oT0.y, v_COLOR.w

};

vertexfragment CelShadingTexCoord1VSelectsColor&{versionString} = 
asm_fragment
{
	vs_&{versionString}

   mov oT0.y, v_TEXCOORD1.y

};


vertexfragment CelShadingTexCoord0VSelectsColor&{versionString} = 
asm_fragment
{
	vs_&{versionString}

   mov oT0.y, v_TEXCOORD0.y

};



vertexfragment CelShadingDiffuseColor&{versionString} = 
asm_fragment
{
	vs_&{versionString}
   
   mov oD0, c_diffuseMaterialColor
   
};


vertexfragment CelShadingSpecular&{versionString} = 
asm_fragment
{
	vs_&{versionString}


   // compute V
   dp3 r_view.w, r_position, r_position
   rsq r_view.w, r_view.w
   mul r_view.xyz, -r_position, r_view.w
   

   // compute H = (L + V) / 2
   
   add r_half, c_lightDirections, r_view
   mul r_half, r_half, c_basics.y   
   
   // normalize H
   dp3 r_half.w, r_half, r_half
   rsq r_half.w, r_half.w
   mul r_half.xyz, r_half, r_half.w
         
   // compute N.H
   
   dp3 r_hdotn.x, r_half, r_temp9
   max r_hdotn.x, r_hdotn, c_basics.x  // clamp to zero.
      
   // The oddball thing about this celshader is that the specular 'shinyness' is not in the V coordinate.
   // instead, the specular ramp is linear, so the power raising has to be done per vertex.
   
   // raise intensity. 

   logp r_hdotn.w, r_hdotn.x
   mul r_hdotn.w, r_hdotn.w, c_textureMatrix[0].y // shinyness factor in Y
   expp r_hdotn.z, r_hdotn.w
   
   mov oT1.xyz, r_hdotn.z
      
};


vertexfragment CelShadingNoPowSpecular&{versionString} = 
asm_fragment
{
	vs_&{versionString}
   // compute V
   dp3 r_view.w, r_position, r_position
   rsq r_view.w, r_view.w
   mul r_view.xyz, -r_position, r_view.w
   
   // compute H = (L + V) / 2
   
   add r_half, c_lightDirections, r_view
   mul r_half, r_half, c_basics.y   
   
   // normalize H
   dp3 r_half.w, r_half, r_half
   rsq r_half.w, r_half.w
   mul r_half.xyz, r_half, r_half.w
   
      
   // compute N.H
   
   dp3 r_hdotn.x, r_half, r_temp9
   max oT1.xyz, r_hdotn.x, c_basics.x  // clamp to zero.

   // specular power is 'in the texture', so don't compute power here.

};





vertexfragment NoTextureMagic&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov oT0, v_TEXCOORD0
};

vertexfragment ObjectSnowShaderTest&{versionString} =
asm_fragment
{
   vs_&{versionString}   
   
   mov r_temp0, v_NORMAL
   mov oT0.x, r_temp0.zzz
   mov r_temp0, v_POSITION
   mul r_temp1.xy, r_temp0.xy, c_helperConstant2.yy
   mul oT1.xy, r_temp1.xy, c_basics.ww
   mov oT2.xyz, r_temp9.xyz
   dp3 r_temp0, r_temp9, c_lightDirections[0]   
   dp3 r_temp1, r_temp9, c_lightDirections[2]
   mul r_temp2, r_temp0, c_lightColors[0]
   mov r_temp0, c_ambientLightColor
   mad r_temp3, c_basics.z, r_temp0, r_temp2
   mad oT3.xyz, r_temp1, c_lightColors[2], r_temp3
};


vertexfragment EyeShifterTexGen&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	// for all verts with the second texcoord.U set, apply a shift given in the eyeShift constant reg.
	// the texture matrix will be overloaded for this.
	

// tex1.y  is the shift scaling amount
//  this has a left and right eye encoded as so:
//  for 0-1 values, this is the right eye
// for 1.0 to 2.0, this is the left eye.

// anmimation channel values: (stored in texture matrix)
// X = Eye Up down
// Y = Eye Left Right
// Z = Left eye anti-stretch value
// W = right eye anti-stretch value


   // keep U the same, but negate V
   mov r_eyeShift.x, c_textureMatrix.x
   mov r_eyeShift.y, -c_textureMatrix.y
         
   // V2 = Eye Scale amount, and left/right indicator.
  
   add r_vertexScaleAmount.x, v_TEXCOORD1.y, -c_basics.z  // subtract one to get -1 to 1 range
    
   // negative values are the right eye.
   slt r_eyeBoolean.y ,r_vertexScaleAmount.xx, c_basics.x  // X = right eye boolean
   add r_eyeBoolean.x, c_basics.z, -r_eyeBoolean.y  // 1.0-right = the left  eye
   
   // ABS
   max r_vertexScaleAbs.z, -r_vertexScaleAmount.x, r_vertexScaleAmount.x
   
   // animation channels L/R * scale for this vertex
   
   mul r_stretcher.zw, c_textureMatrix.zwzw, r_vertexScaleAbs.z
   mul r_stretcher.zw, r_eyeBoolean.xyxy, r_stretcher.zwzw  // each channel * the eye channel selector

   add r_eyeShift.x, r_eyeShift.x, r_stretcher.z  // add in left eye amount (if non zero)
   add r_eyeShift.x, r_eyeShift.x, r_stretcher.w // add in right eye amount (if non zero)

   // Finally: apply Is eye or  not boolean.
   mul r_eyeShift.xy, r_eyeShift.xy, v_TEXCOORD1.xx
   
   // final op is just going to be a shift in UV space.
  
  add oT0.xy, r_eyeShift, v_TEXCOORD0
  
   
   
};

vertexfragment TextureMatrix2DTransformTex0&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	// swizzle will take the input vector of XY, 0, 1 and make it X,Y,1,0
	// since the 3rd column of the matrix seems to be translation.
	
	dp4 oT0.x, v_TEXCOORD0.xywz, c_textureMatrix
	dp4 oT0.y, v_TEXCOORD0.xywz, c_textureMatrix[1]
};

vertexfragment  Copy2DTexcoordsToTex1&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov oT1.xy, v_TEXCOORD0
	
};

vertexfragment  TexGenCameraSpacePosition&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov oT0.xyz, r_temp8
};


vertexfragment TransformViewVectorToLocalSpace&{versionString} = 
asm_fragment
{
	vs_&{versionString}

// View, surface normal (0,0,1 or from bumpmap), light Vectors

	dp3 r_viewVector.w, r_temp8, r_temp8
	rsq r_viewVector.w, r_viewVector.w
	mul r_viewVector.xyz, r_viewVector.w, -r_temp8

	dp3 oT7.x, r_viewVector, r_tangent
	dp3 oT7.y, r_viewVector, r_binormal
	dp3 oT7.z, r_viewVector, r_temp9
		
			
};


vertexfragment WaterMaterialStuff&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	
	mov oD0.xyzw, c_lerpWaterWave.x

	dp4 oT0.x, v_TEXCOORD0.xywz, c_textureMatrix[0]
	dp4 oT0.y, v_TEXCOORD0.xywz, c_textureMatrix[1]

	dp4 oT1.x, v_TEXCOORD0.xywz, c_waterScaleWave2[0]
	dp4 oT1.y, v_TEXCOORD0.xywz, c_waterScaleWave2[1]

		
};



vertexfragment WaterMaterialStuffSWVS&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	
	mov oD0.w, c_lerpWaterWave.x

	dp4 oT0.x, v_TEXCOORD0.xywz, c_textureMatrix[0]
	dp4 oT0.y, v_TEXCOORD0.xywz, c_textureMatrix[1]
		
};


vertexfragment VertexAlphaSupport&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov oD0, v_COLOR
	
};



endShaderSource

enddef



define VS3UniqueTexgenFragments()

shaderSource


vertexfragment NoTextureMagic3_0 = 
asm_fragment
{
	vs_3_0

	mov o_TEXCOORD0.xy, v_TEXCOORD0
};


vertexfragment EyeShifterTexGen3_0 = 
asm_fragment
{
	vs_3_0
	
	// for all verts with the second texcoord.U set, apply a shift given in the eyeShift constant reg.
	// the texture matrix will be overloaded for this.
	

// tex1.y  is the shift scaling amount
//  this has a left and right eye encoded as so:
//  for 0-1 values, this is the right eye
// for 1.0 to 2.0, this is the left eye.

// anmimation channel values: (stored in texture matrix)
// X = Eye Up down
// Y = Eye Left Right
// Z = Left eye anti-stretch value
// W = right eye anti-stretch value


   // keep U the same, but negate V
   mov r_eyeShift.x, c_textureMatrix.x
   mov r_eyeShift.y, -c_textureMatrix.y
         
   // V2 = Eye Scale amount, and left/right indicator.
  
   add r_vertexScaleAmount.x, v_TEXCOORD1.y, -c_basics.z  // subtract one to get -1 to 1 range
    
   // negative values are the right eye.
   slt r_eyeBoolean.y ,r_vertexScaleAmount.xx, c_basics.x  // X = right eye boolean
   add r_eyeBoolean.x, c_basics.z, -r_eyeBoolean.y  // 1.0-right = the left  eye
   
   // ABS
   max r_vertexScaleAbs.z, -r_vertexScaleAmount.x, r_vertexScaleAmount.x
   
   // animation channels L/R * scale for this vertex
   
   mul r_stretcher.zw, c_textureMatrix.zwzw, r_vertexScaleAbs.z
   mul r_stretcher.zw, r_eyeBoolean.xyxy, r_stretcher.zwzw  // each channel * the eye channel selector

   add r_eyeShift.x, r_eyeShift.x, r_stretcher.z  // add in left eye amount (if non zero)
   add r_eyeShift.x, r_eyeShift.x, r_stretcher.w // add in right eye amount (if non zero)

   // Finally: apply Is eye or  not boolean.
   mul r_eyeShift.xy, r_eyeShift.xy, v_TEXCOORD1.xx
   
   add o_TEXCOORD0.xy, r_eyeShift, v_TEXCOORD0
    
   
};


endShaderSource


enddef




shaderProgram -target fragments -method addFragment 

shaderSource

float4x4 cameraToClipSpaceMatrix : register(c0); // 0,1,2,3
float4x4 objectToClipSpaceMatrix : register(c4); // 4,5,6,7
float4x3 objectToCameraSpaceMatrix : register(c8); // 8,9, 10

float4x3  textureMatrix : register(c11); //11, 12, 13

float4  diffuseMaterialColor : register (c14);
float4  specularMaterialColor : register (c15);
float4  ambientLightColor : register (c16);
float4 emissiveColor : register(c17);  // a few materials actually use this crap.

// 8 of each.
float4 lightDirections[8] : register (c18); // w = light range 18, 19, 20, 21, 22, 23, 24, 25
float4 lightColors[8] : register(c26); //  .w = cone angle constant , 18..21, 22..25
float4 lightPositions[8] : register (c34);     // .w = falloff rate, 
float4 lightAttenuation[2] : register (c42); // 42, 43
float4 lightRanges[2] : register(c44);
float4 spotConeHelper1 : register(c46);
float4 spotConeHelper2 : register(c48);

// these coincide now with pose data
float4 morphWeights : register (c56); // stored in the W channel.

// from here to the end of constant register space is the pose matrix array.
// VS 2.0 = 204 registers for pose transforms, which is 68 packed 4x3s or 102 quaternions +translations
// VS 1.0 = 44 registers for poses, which is 14 packed 4x3s or 22 quaternions+ translations

float4 poseDataRow1 : register(c56);
float4 poseDataRow2 : register(c57);
float4 poseTranslation : register(c58);

static const float4 helperConstant1 : register(c50) = float4( 765.01,-1,1, 4);
static const float4 helperConstant2 : register(c51) = float4(255,3,0.5,0.0001); //.w is 'epsilon' for ndotl computations
static const float4 basics : register(c52) = float4(0,0.5,1,2);

// Morphs first, then the unpacked pose transforms follow.

float4 lerpWaterWave : register(c250); // no pose matricies up here for the water, I hope...
float4x2 waterScaleWave2 : register(c253); 

float4x3 cubemapMatrix : register(c253); // 253, 254, 255

float4 unpackedPoseMatrixRow1 : register(c90);
float4 unpackedPoseMatrixRow2 : register(c91);
float4 unpackedPoseMatrixRow3 : register(c92);

float4x3 unpackedPoseMatrix : register(c90);

endShaderSource




	create VertexShaderLightingFragments()
	create VertexShaderTransformFragments()
	create VertexShaderPixelLightingFragments()

	create VSSharedFragments(2_0)
	create VSSharedFragments(2_x)
	create VSSharedFragments(1_1)
	
	create VS3UniqueTexgenFragments()
	
end #the 'global' shader program for fragments



define DetermineHardwareSupport()

   setb useHWShader2Path false
   setb useHWShader1Path false
   setb useSWVertexShaderPath false
   setb useFixedFunctionPath true
     
    
	setb ubyte4Supported true # assume SWVP/DX9 cards is true.
	
   
	seti psVersion (queryIntegerGraphicsDeviceCap(maxPixelProgramVersionMajor))
	seti vsVersion (queryIntegerGraphicsDeviceCap(maxVertexProgramVersionMajorHW))

	setb ffgpHW (queryBooleanGraphicsDeviceCap(hasFixedFunctionVPHW))

#<
	trace "ffgpHW: $ffgpHW"
	trace "VS: $vsVersion  PS: $psVersion"
#>

   setb cubeMapSupport (queryBooleanGraphicsDeviceCap(hasCubeMapSupport))
   
   if ($psVersion > 2 and (not $kUsePS30))
      seti psVersion 2
   endif     
   
	if ($kUseShaderPrograms)

		# if no	fixed function HW, or it's been	forced off,	use	the	SW vertex shader path.	 
		
			if ($psVersion >= 2 and not $kForceNoDX9)	
				setb	useHWShader2Path true
				setb	useHWShader1Path false
				setb	useSWVertexShaderPath false
				setb	useFixedFunctionPath false
				
			elseif ($psVersion >= 1 and not $kForceNoDX8)	
			# set to the real HW support from the HW caps.
				setb ubyte4Supported (queryBooleanGraphicsDeviceCap(hasUByte4VertexType))
				setb useHWShader1Path false
				setb useHWShader1Path true
				setb useSWVertexShaderPath false
				setb useFixedFunctionPath false
		
			elseif ((not	$ffgpHW and $psVersion = 0) or $kForceNoDX7)
				setb useSWVertexShaderPath	true
				setb useHWShader1Path false
				setb useHWShader2Path false
				setb useFixedFunctionPath false
            
			endif
			  
		
		
		
#  These lines are unlikely to fix errors nowadays, please contact Timothy Wilson (tewilson@maxis.com) before messin' with 'em.

	#setb bumpMapping false
	# stuff useful for matshad debugging.
#<
    setb useHWShader2Path false
	setb useHWShader1Path false
	setb useSWVertexShaderPath false
	setb useFixedFunctionPath false

	setb useHWShader1Path true
#>
  
		if ( $useHWShader2Path )
			if	( numPoseTransforms	> 60)
				seti npt numPoseTransforms
				trace "NumPoseTransforms is	$npt for (limit	65 for DX9)	$currentMaterialName, not accelerated by hardware"
				setb useHWShader2Path false
				setb useHWShader1Path false
				setb useSWVertexShaderPath false
				setb useFixedFunctionPath true
			endif
		endif


# no longer doing xforms on GPU in this case, so don't check for bad things...
		if ($useHWShader1Path)
			if	( numPoseTransforms	> 13)
				seti npt numPoseTransforms
				trace "NumPoseTransforms is	$npt for(limit 13 for DX8) $currentMaterialName, not accelerated by	hardware"
				setb useHWShader2Path false
				setb useHWShader1Path false
				setb useSWVertexShaderPath false
				setb useFixedFunctionPath true
			endif
		endif



	endif  #	use	shader programs
   


	
   


#<

	if ($useSWVertexShaderPath)
		trace "Final Path = software VS $currentMaterialName"
	else
		if ($useHWShader2Path)
			trace "Final Path = Hardware VS 2.0 $currentMaterialName"
		else
			if ($useHWShader1Path)
				trace "Final Path = Hardware VS 1.1 $currentMaterialName"
			else
				trace "Final Path = Fixed Function $currentMaterialName"
			endif
		endif
	endif
#>


	
	
enddef



define DetermineLightingMode()
	
	setf diffuseColorAccum 0.0
	setf specularColorAccum 0.0
	
	if ($stdMatLightingEnabled and $hasNormals)
		#trace "   Lighting Desired, and normals exist"
		validateRenderShaderContext -vertexFormat normal 0 required
	else
		setb $stdMatLightingEnabled false
		#trace "   Lighting Disabled, no normals"
	endif

	seti lightingMode $kNoLighting     

	if ($stdMatLightingEnabled)
		
		setv3 evalShaderDiffuse (($stdMatDiffCoef).xyz)
		setv3 evalShaderSpecular (($stdMatSpecCoef).xyz)

		setf diffuseColorAccum  ($evalShaderDiffuse.x + $evalShaderDiffuse.y + $evalShaderDiffuse.z)
		setf specularColorAccum ($evalShaderSpecular.x + $evalShaderSpecular.y + $evalShaderSpecular.z)
					
		if ($hasNormals) 
			if ($diffuseColorAccum = 0 and $specularColorAccum = 0)
				#trace "Lighting is on, but diffuse and specular are BLACK, disabling lighting"
				seti lightingMode $kNoLighting
			else
				seti lightingMode $kFullLighting
			endif
		else
			seti lightingMode $kAmbientOnly
		endif
			
		if ($totalLights = 0)
			#trace "Lighting is on, but no lights were found, switching to ambient only"
			seti lightingMode $kAmbientOnly
		endif
		
	endif
	
   if (strcmp("${stdMatAlphaBlendMode}","additive") = 0)
      seti lightingMode $kNoLighting
   endif
         
	#trace "Final lighting mode: $lightingMode"
	
enddef




define SetupCommonHWShaderVariablesAndPredicates()

	seti distantLightCount (numLightsOfType(directional))
	seti pointLightCount (numLightsOfType(point))
	seti spotLightCount (numLightsOfType(spot))

#<
	trace "---------------------------"
	trace "Starting material: $currentMaterialName"
	trace "DistantLight Count: $distantLightCount"
	trace "Point Light Count: $pointLightCount"
	trace "spot light Count: $spotLightCount"
#>

	
	seti totalLights ($distantLightCount + $pointLightCount + $spotLightCount)
	seti perPixelLightCount 0
	
	setb  hasTexcoords (hasVertexFormat(texcoord,0))
	setb  hasNormals (hasVertexFormat(normal,0))
	setb  hasTangents (hasVertexFormat(tangent,0))
	setb  hasColor (hasVertexFormat(color,0))
	seti  bonesPerVertex (maxBonesPerVertex)

	#<
   if ($hasNormals)
		# we only need light predicates if normals exist.
		validateRenderShaderContext -numLights directional $distantLightCount
		validateRenderShaderContext -numLights point $pointLightCount
		validateRenderShaderContext -numLights spot $spotLightCount
	endif
	#>
	
	create SetupSkinningStateAndPredicates()
	create SetupMorphingStateAndPredicates()

   setb updateEachFrameFlag false
   
   # if not equal to 'none', then it must be set to *something*, so it's animating, and needs updating each frame
   if (strcmp("${stdMatTextureCoordAnimMode}", "none"))
      setb updateEachFrameFlag true
   endif
   

enddef





define 	VertexShaderTextureMatrixAnimation()

	if (strcmp("${stdMatTextureCoordAnimMode}", "transform") = 0)
		#trace "Texture matrix animation enabled $currentMaterialName"
		
		if ($stdMatTextureCoordTfAnimScaleStartEnd.x = 0.0)
			setv2 stdMatTextureCoordTfAnimScaleStartEnd (0.001, $stdMatTextureCoordTfAnimScaleStartEnd.y)
		endif
			
		textureMatrixAnimation -targetType vsConstants -targetRegister 11 -aorigin $stdMatTextureCoordTfAnimOrigin -arot $stdMatTextureCoordTfAnimRotWaveform $stdMatTextureCoordTfAnimRotSpeed 0 $stdMatTextureCoordTfAnimRotStartEnd -ascale $stdMatTextureCoordTfAnimScaleWaveform $stdMatTextureCoordTfAnimScaleSpeed 0 $stdMatTextureCoordTfAnimScaleStartEnd -atrans $stdMatTextureCoordTfAnimTransWaveform $stdMatTextureCoordTfAnimTransSpeed 0 $stdMatTextureCoordTfAnimTransStart $stdMatTextureCoordTfAnimTransEnd
	endif

	if (strcmp("${stdMatTextureCoordAnimMode}", "tile") = 0)
		#trace "Texture tile animation enabled $currentMaterialName"
		textureTileAnimation $stdMatTextureCoordTileAnimSpeed -tiles $stdMatTextureCoordAnimNumTiles -targetType vsConstants -targetRegister 11
	endif

	if (strcmp("${stdMatTextureCoordAnimMode}", "video")	= 0)
	  #trace("video texture mode\n")
	  sendNotifyString $shaderNotifyString
	endif
	
	
enddef




define TestForEyeMotion()

   setb eyeMotion false
   
   # sniff test 'single layer face fix'
   if (varExists(simSkinFlag) = false)
      setb simSkinFlag false
   endif

	if (hasVertexFormat(texcoord, 1) = false)
		setb eyeMotion false
    else
        if (varExists(eyeGizmoEnable) = false)
            setb eyeMotion false
        else
            setb eyeMotion $eyeGizmoEnable
        endif
	endif

# sniff test 'single layer face fix'
    if ($simSkinFlag = false)
        setb eyeMotion false
    endif

enddef


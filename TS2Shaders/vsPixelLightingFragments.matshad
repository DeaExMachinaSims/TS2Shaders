


define VertexShaderPixelLightingFragments()

	create VS2SharedPixelLightingFragments(2_0)
	
	create VS1PixelLightingFragments()
	
enddef





define VS2SharedPixelLightingFragments(versionString)

shaderSource


vertexfragment TransformTangentSpaceWithCompositeMatrix&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	// composite matrix is (still) in 5,6,7
	// transform tangent into local space.
	
	dp3 r_tangent.x, v_TANGENT, r_temp5
	dp3 r_tangent.y, v_TANGENT, r_temp6
	dp3 r_tangent.z, v_TANGENT, r_temp7

	// cross to get the binormal, to assure orthoganal-ism.
	crs r_binormal.xyz, r_tangent, r_temp9  // Binormal = csTangent X csNormal

};




vertexfragment TransformTangentSpaceNoSkinning&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	m3x3 r_tangent.xyz, v_TANGENT, c_objectToCameraSpaceMatrix
	
	crs r_binormal.xyz, r_tangent, r_temp9  // Binormal = csTangent X csNormal

};



vertexfragment PixelLightingDistantSetupX&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	dp3 r_lightVector.x, c_lightDirections[a0.x], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x], r_temp9   // camera normal


};


vertexfragment PixelLightingDistantSetupY&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	dp3 r_lightVector.x, c_lightDirections[a0.x+1], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x+1], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x+1], r_temp9   // camera normal


};


vertexfragment PixelLightingDistantSetupXY&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	dp3 oT4.x, c_lightDirections[a0.x], r_tangent  // camera tangent
	dp3 oT4.y, c_lightDirections[a0.x], r_binormal  // camera binormal
	dp3 oT4.z, c_lightDirections[a0.x], r_temp9   // camera normal
		
	dp3 oT5.x, c_lightDirections[a0.x+1], r_tangent  // camera tangent
	dp3 oT5.y, c_lightDirections[a0.x+1], r_binormal  // camera binormal
	dp3 oT5.z, c_lightDirections[a0.x+1], r_temp9   // camera normal
	
};


vertexfragment PixelLightingDistantSetupXYZ&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	dp3 oT4.x, c_lightDirections[a0.x], r_tangent  // camera tangent
	dp3 oT4.y, c_lightDirections[a0.x], r_binormal  // camera binormal
	dp3 oT4.z, c_lightDirections[a0.x], r_temp9   // camera normal
		
	dp3 oT5.x, c_lightDirections[a0.x+1], r_tangent  // camera tangent
	dp3 oT5.y, c_lightDirections[a0.x+1], r_binormal  // camera binormal
	dp3 oT5.z, c_lightDirections[a0.x+1], r_temp9   // camera normal

	dp3 oT6.x, c_lightDirections[a0.x+2], r_tangent  // camera tangent
	dp3 oT6.y, c_lightDirections[a0.x+2], r_binormal  // camera binormal
	dp3 oT6.z, c_lightDirections[a0.x+2], r_temp9   // camera normal

};



// in general, only the 3rd light matters, since I only bump map 3 lights at the max, and the first 2 are (always) distant lights.

vertexfragment PixelLightingPointSpotSetupZ&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_lightVector.x, r_temp6, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp6, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp6, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.z, r_lightVector
};




vertexfragment PixelLightingPointSpotSetupX&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_lightVector.x, r_temp6, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp6, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp6, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.x, r_lightVector

};



// just in case these cases show up.
vertexfragment PixelLightingPointSpotSetupY&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_lightVector.x, r_temp5, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp5, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp5, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.y, r_lightVector

};


vertexfragment PixelLightingPointSpotSetupW&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_lightVector.x, r_temp7, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp7, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp7, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.w, r_lightVector
	
};

vertexfragment ZeroDiffuse&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov r_diffuse_r2, c_basics.x
	
};


vertexfragment WriteLightVectorToTex4&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov oT4.xyz, r_lightVector

};

vertexfragment WriteLightVectorToTex5&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov oT5.xyz, r_lightVector
	
};


vertexfragment WriteLightVectorToTex6&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov oT6.xyz, r_lightVector
	
};


endShaderSource

enddef




define VS1PixelLightingFragments()

shaderSource


vertexfragment ZeroDiffuse1_1 = 
asm_fragment
{
	vs_1_1
	
	mov r_diffuse_r2, c_basics.x
	
};



vertexfragment TransformTangentSpaceWithCompositeMatrix1_1 = 
asm_fragment
{
	vs_1_1
	
	// composite matrix is (still) in 5,6,7
	// transform tangent into local space.
	
	dp3 r_tangent.x, v_TANGENT, r_temp5
	dp3 r_tangent.y, v_TANGENT, r_temp6
	dp3 r_tangent.z, v_TANGENT, r_temp7

	// cross to get the binormal, to assure orthoganal-ism.
	mul r_binormal.xyz, r_tangent.yzx, r_temp9.zxy
	mad r_binormal.xyz, -r_tangent.zxy, r_temp9.yzx, r_binormal
	
	mov oT1.xy, v_TEXCOORD
};




vertexfragment TransformTangentSpaceNoSkinning1_1 = 
asm_fragment
{
	vs_1_1

	m3x3 r_tangent.xyz, v_TANGENT, c_objectToCameraSpaceMatrix
	
	mul r_binormal.xyz, r_tangent.yzx, r_temp9.zxy
	mad r_binormal.xyz, -r_tangent.zxy, r_temp9.yzx, r_binormal

	mov oT1.xy, v_TEXCOORD

};


vertexfragment PixelLightingDistantSetupX1_1 = 
asm_fragment
{
	vs_1_1

	dp3 r_lightVector.x, c_lightDirections[a0.x], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x], r_temp9   // camera normal

	mad oD1.xyz, r_lightVector, c_basics.y, c_basics.y  // compress into unsigned range.
};


vertexfragment PixelLightingDistantSetupXY1_1 = 
asm_fragment
{
	vs_1_1

	dp3 r_lightVector.x, c_lightDirections[a0.x], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x], r_temp9   // camera normal

	mad oD1.xyz, r_lightVector, c_basics.y, c_basics.y

	dp3 r_lightVector.x, c_lightDirections[a0.x+1], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x+1], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x+1], r_temp9   // camera normal

	mad oT3.xyz, r_lightVector, c_basics.y, c_basics.y

};


// T0 = base texture map coordindates
// T1 = normal map coordinates (copy for PS1.1)
// T2 = Light Vector 1
// T3 = light Vector 2
// V0 = Vertex diffuse color/ambient
// V1 = light Vector 3


vertexfragment PixelLightingDistantSetupXYZ1_1 = 
asm_fragment
{
	vs_1_1

	dp3 r_lightVector.x, c_lightDirections[a0.x], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x], r_temp9   // camera normal

	mad oD1.xyz, r_lightVector, c_basics.y, c_basics.y

	dp3 r_lightVector.x, c_lightDirections[a0.x+1], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x+1], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x+1], r_temp9   // camera normal

	mad oT2.xyz, r_lightVector, c_basics.y, c_basics.y
	
	dp3 r_lightVector.x, c_lightDirections[a0.x+2], r_tangent  // camera tangent
	dp3 r_lightVector.y, c_lightDirections[a0.x+2], r_binormal  // camera binormal
	dp3 r_lightVector.z, c_lightDirections[a0.x+2], r_temp9   // camera normal

	mad oT3.xyz, r_lightVector, c_basics.y, c_basics.y

};





vertexfragment PixelLightingPointSpotSetupZ1_1 = 
asm_fragment
{
	vs_1_1
	
	dp3 r_lightVector.x, r_temp6, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp6, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp6, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.z, r_lightVector  // pre-scale the outbound vector for attenuation.


};



vertexfragment PixelLightingPointSpotSetupW1_1 = 
asm_fragment
{
	vs_1_1
	
	dp3 r_lightVector.x, r_temp7, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp7, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp7, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.w, r_lightVector  // pre-scale the outbound vector for attenuation.


};



vertexfragment PixelLightingPointSpotSetupY1_1 = 
asm_fragment
{
	vs_1_1
	
	dp3 r_lightVector.x, r_temp5, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp5, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp5, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.y, r_lightVector  // pre-scale the outbound vector for attenuation.
};



vertexfragment PixelLightingPointSpotSetupX1_1 = 
asm_fragment
{
	vs_1_1
	
	dp3 r_lightVector.x, r_temp4, r_tangent  // camera tangent
	dp3 r_lightVector.y, r_temp4, r_binormal  // camera binormal
	dp3 r_lightVector.z, r_temp4, r_temp9   // camera normal

	mul r_lightVector.xyz, r_attenuation.x, r_lightVector  // pre-scale the outbound vector for attenuation.
};


vertexfragment WriteLightVectorToSpecular1_1 = 
asm_fragment
{
	vs_1_1
	
	mad oD1.xyz, r_lightVector, c_basics.y, c_basics.y  // compress into unsigned range.
	
};


vertexfragment WriteLightVectorToTex21_1 = 
asm_fragment
{
	vs_1_1
	
	mad oT2.xyz, r_lightVector, c_basics.y, c_basics.y  // compress into unsigned range.
	
};


vertexfragment WriteLightVectorToTex31_1 = 
asm_fragment
{
	vs_1_1
	
	mad oT3.xyz, r_lightVector, c_basics.y, c_basics.y  // compress into unsigned range.
	
};


endShaderSource

enddef

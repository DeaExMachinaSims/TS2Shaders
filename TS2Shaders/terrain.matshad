   addParam stdMatEnvCubeTextureName reflectionkitchenhighcontrast-envcube
   addParam stdMatFillMode solid
   addParam stdMatLayer 0
   addParam stdMatLightingEnabled 1
   addParam stdMatMinLightRangeHint 4

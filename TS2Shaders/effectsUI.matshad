# The following definitions were copied from the steam sphere to make a uieffect shader.
# This is a test shader to help in evolving the UI headline FX.  
# C Stratton 4/27/03
#


#
# This shader differs from the effects shader in that it ignores zbuffer.    
# and may be extended further to accomodate UI specific needs
# 
# beginshader uiHeadlineBillboardTest
define uiHeadlineBillboardTest()
      material
         shader -layer 0
            vertexFormatPred blendindices  0 false
            vertexFormatPred targetindices 0 false
            #vertexFormatPred position 0 true
            create BillboardPass($stdMatBaseTextureName 0 (0, 0))
         end
      end
enddef
#endshader uiHeadlineBillboardTest


define BillboardPass (BillboardTexture speed origin)
   pass -fixedFunction
      # using depthTest (below) to ignore z-depth
      depthTest false -enableDepthWrite false
      alphaBlend srcFactor(srcAlpha) add dstFactor(invSrcAlpha)      
      stage
         texture &BillboardTexture
         # Following two lines correct for UV flip in particle billboards
         ffTextureMatrix -scalev (1, -1)
         textureTransformType vector2
         textureBlend add(texture) multiply(texture diffuse)
         #
      end      
   end
enddef



# Billboard Material Definitions

materialDefinition uieffectsHeadlines_Romance
   setDefinition uiHeadlineBillboardTest
   addParam stdMatLightingEnabled false
   addParam stdMatAlphaBlendMode blend
   addParam stdMatBaseTextureEnabled true
   addParam stdMatBaseTextureName uieffects-headlines-billboardtextures-romance
end


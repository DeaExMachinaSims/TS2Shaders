#
# The following shader is for strip animations applied to particle billboard effects
# C Stratton 4/18/03
#

# beginshader uiHeadlineBillboardAnimationTest
define uiHeadlineBillboardAnimationTest()
      material
         shader -layer 0
            #vertexFormatPred position 0 true
            create BillboardAniPass($stdMatBaseTextureName 0 (0, 0))
         end
      end
enddef
#endshader uiHeadlineBillboardAnimationTest


define BillboardAniPass (BillboardTexture speed origin)
   pass -fixedFunction
      # using depthTest (below) to ignore z-depth
      depthTest false -enableDepthWrite false
      alphaBlend srcFactor(srcAlpha) add dstFactor(invSrcAlpha)      
      stage
         texture &BillboardTexture
         #
         # Following two lines correct for UV flip in particle billboards
         # Note that if ffTextureTileAnim is used, these commands are somehow overridden.
         #
         #ffTextureMatrix -scalev (1, -1)
         #textureTransformType vector2
         #
         # Following line is for animation strips (conversation and thought balloons)
         #
         textureTileAnimation 1 -tiles (18,1) -targetType fixedFunction
         #
         textureBlend add(texture) multiply(texture diffuse)
         #
      end      
   end
enddef

materialDefinition uieffectsHeadlinesAni_ThoughtBalloonTest
   setDefinition uiHeadlineBillboardAnimationTest
   addParam stdMatLightingEnabled false
   addParam stdMatAlphaBlendMode blend 
   addParam stdMatBaseTextureEnabled true
   addParam stdMatBaseTextureName uieffects-headlines-anistriptextures-thoughtballoon18_test
end



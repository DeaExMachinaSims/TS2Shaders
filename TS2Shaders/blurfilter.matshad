


define PassThroughVertexShader()
	
	shaderProgram -target vertexProgram -method assemble
	
		
		shaderSource
			vs_1_1
			def c0,0,0.0078125,0,0 
			def c1, 0,0.5,1,2
         def c2, 0.5, -0.5, 0.5, 0.5
         def c11, 0.001953125, -0.001953125 , 0.009125,   -0.00390625
			dcl_position v0
			dcl_texcoord v1
			
			mov oPos, v0
			mad r0.xy, v0, c2.xy, c2.zw
         
         add oT0.xy, r0, c11.zy
         add oT1.xy, r0, c11.zy
         
			mad oT2.xy, v0, c1.y, c1.y
				
		endShaderSource
	
	end
	
enddef



define PassThroughVertexShader2(imageScaleX imageScaleY imageOffsetX imageOffsetY sampleScaleX sampleScaleY sampleOffsetX sampleOffsetY)
	
	shaderProgram -target vertexProgram -method assemble
      
      bindConstants 1 -bindingID immediateData -data(&imageScaleX, &imageScaleY, &imageOffsetX,&imageOffsetY)
      bindConstants 2 -bindingID immediateData -data(&sampleScaleX, &sampleScaleY, &sampleOffsetX, &sampleOffsetY)
	
		shaderSource
			vs_1_1
			def c0, 0,0.5,1,2
			dcl_position v0
			dcl_texcoord v1
			
			;mov oPos, v0
         mad r0, v0, c0.y, c0.y  ; clip(-1->1) to screen0->1 coords

         mad r1.xy, r0, c1.xy, c1.zw  ; apply my scale and offset in 0-1 space.
     
         mad oPos.xy, r1, c0.w, -c0.z  ; screen back to clip
         
         mov oPos.zw, v0
         
         mad oT0.xy, r0, c2.xy, c2.zw  ; apply scale and offset for the sampling
         
		endShaderSource
	
	end
	
enddef


define GenericFilterVertexShader(side dimension imageScaleX imageScaleY imageOffsetX imageOffsetY sampleScaleX sampleScaleY sampleOffsetX sampleOffsetY)
	
	shaderProgram -target vertexProgram -method assemble
	
		if (&side = 0)
			create LeftSideOffsets(&dimension)
		endif
		
		if (&side = 1)
			create RightSideOffsets(&dimension)
		endif
		
		if (&side = 2)
			create TopSideOffsets(&dimension)
		endif

		if (&side = 3)
			create BottomSideOffsets(&dimension)
		endif

      bindConstants 50 -bindingID immediateData -data(&imageScaleX, &imageScaleY, &imageOffsetX,&imageOffsetY)
      bindConstants 51 -bindingID immediateData -data(&sampleScaleX, &sampleScaleY, &sampleOffsetX, &sampleOffsetY)

		shaderSource
			vs_1_1
			
         def c10, 0,0.5,1,2
         def c11, 0.001953125, -0.001953125 , -0.00390625,   0.00390625
			dcl_position v0
			;dcl_texcoord v1

         ; convert clip space to screen (0,0 to 1,1)
         mad r0.xy, v0, c10.y, c10.y   ; -1 -> 1 to -0.5 ->0.5 to 0 -> 1
         
         
         mad r1.xy, r0, c50.xy, c50.zw ; scale for the image write part (to use only a portion of the dest, in top left corner.)
         
         ; convert back to -1,-1 -> 1,1 clip space relative 

         mad oPos.xy, r1, c10.w, -c10.z   ; ScreenXY * 2 - 1

         mov oPos.zw, v0
         
         mad r0.xy, r0, c51.xy, c51.zw ; scale the samples if only a portion is needed.
         
			add oT0.xy, r0, c4
			add oT1.xy, r0, c5	
			add oT2.xy, r0, c6	
			add oT3.xy, r0, c7	
				
		endShaderSource
	
	end
	
enddef



define LeftSideOffsets(textureSize)

	setf texelSize (-1.0/&textureSize)
	
	setf texelSizeX2 ($texelSize * 2)
	setf texelSizeX3 ($texelSize * 3)

	setf pixelOffset ((-1.0/&textureSize)/2)

	# 3 texels to the left.
	bindConstants 4 -bindingID immediateData -data ($texelSizeX3,0,0,0)
	bindConstants 5 -bindingID immediateData -data ($texelSizeX2,0,0,0)
	bindConstants 6 -bindingID immediateData -data ($texelSize,0,0,0)
	# dead on sample point
	bindConstants 7 -bindingID immediateData -data (0,0,0,0)
	bindConstants 8 -bindingID immediateData -data ($pixelOffset, $pixelOffset,0,0)

enddef


define RightSideOffsets(textureSize)

	setf texelSize (1.0/&textureSize)
	
	setf texelSizeX2 ($texelSize * 2)
	setf texelSizeX3 ($texelSize * 3)
	setf texelSizeX4 ($texelSize * 4)

	setf pixelOffset ((-1.0/&textureSize)/2)

	# 1 texel to the right of the main sample
	bindConstants 4 -bindingID immediateData -data ($texelSize,0,0,0)
	# 2 texels over
	bindConstants 5 -bindingID immediateData -data ($texelSizeX2,0,0,0)
	# 3 texels over to the right
	bindConstants 6 -bindingID immediateData -data ($texelSizeX3,0,0,0)
	bindConstants 7 -bindingID immediateData -data (0,0,0,0)
	bindConstants 8 -bindingID immediateData -data ($pixelOffset, $pixelOffset,0,0)

enddef


define TopSideOffsets(textureSize)

	setf texelSize (-1.0/&textureSize)
	
	setf texelSizeX2 ($texelSize * 2)
	setf texelSizeX3 ($texelSize * 3)
	setf pixelOffset ((-1.0/&textureSize)/2)

	# 3 texels to the left.
	bindConstants 4 -bindingID immediateData -data (0,$texelSizeX3,0,0)
	bindConstants 5 -bindingID immediateData -data (0,$texelSizeX2,0,0)
	bindConstants 6 -bindingID immediateData -data (0,$texelSize,0,0)
	# dead on sample point
	bindConstants 7 -bindingID immediateData -data (0,0,0,0)
	bindConstants 8 -bindingID immediateData -data ($pixelOffset, $pixelOffset,0,0)


enddef


define BottomSideOffsets(textureSize)

	setf texelSize (1.0/&textureSize)
	
	setf texelSizeX2 ($texelSize * 2)
	setf texelSizeX3 ($texelSize * 3)
	setf texelSizeX4 ($texelSize * 4)
	setf pixelOffset ((-1.0/&textureSize)/2)

	# 1 texel to the right of the main sample
	bindConstants 4 -bindingID immediateData -data (0,$texelSize,0,0)
	# 2 texels over
	bindConstants 5 -bindingID immediateData -data (0,$texelSizeX2,0,0)
	# 3 texels over to the right
	bindConstants 6 -bindingID immediateData -data (0,$texelSizeX3,0,0)
	bindConstants 7 -bindingID immediateData -data (0,0,0,0)
	bindConstants 8 -bindingID immediateData -data ($pixelOffset, $pixelOffset,0,0)

enddef



# Step 1: Render 'to-be-bloomed' image into RT1


# Step 2: Render "Left Side" of bloom into RT2, source RT1

# Step 3: Render "Right Side" of bloom into RT2, source RT1 using ADD mode.

# Step 4: Render "Top Half" of bloom onto main FB, source RT2

# step 5: REnder "Bottom Half" of bloom onto main FB, source RT2




# Four samples on this pass.
define FirstSideGaussianPixelShader()

	shaderProgram -target pixelProgram -method assemble
		
			shaderSource
				ps_1_1

				def c0,0,0,0,0.025089606
				def c1,0,0,0,0.143369176
				def c2,0,0,0,0.215053763
				def c3,0,0,0,0.23297491

				tex t0   ;  3 pixels to the 'left'
				tex t1
				tex t2
				tex t3   ; the center of the filter.

				mul r0, t0, c0.a
				mad r0, t1, c1.a, r0
				mad r0, t2, c2.a, r0
				mad r0, t3, c3.a, r0
			
			endShaderSource

	end	
		

enddef



define FirstBoxFilterPixelShader()

	shaderProgram -target pixelProgram -method assemble
		
			shaderSource
				ps_1_1

				def c0,0,0,0,0.14; 1/49 (7x7 = 49)

				tex t0   ;  3 pixels to the 'left'
				tex t1
				tex t2
				tex t3   ; the center of the filter.

				mul r0, t0, c0.a
				mad r0, t1, c0.a, r0
				mad r0, t2, c0.a, r0
				mad r0, t3, c0.a, r0
			
			endShaderSource

	end	
		

enddef



define LastBoxFilterPixelShader()

	shaderProgram -target pixelProgram -method assemble
		
			shaderSource
				ps_1_1

				def c0,0,0,0,0.14   ; 1/49 (7x7 = 49)

				tex t0   ;  3 pixels to the 'left'
				tex t1
				tex t2

				mul r0, t0, c0.a
				mad r0, t1, c0.a, r0
				mad r0, t2, c0.a, r0
			
			endShaderSource

	end	
		

enddef



# only 3 samples on this pass
define LastSideGaussianPixelShader()

	shaderProgram -target pixelProgram -method assemble
		
			shaderSource
				ps_1_1
				
				def c0,0,0,0,0.025089606
				def c1,0,0,0,0.143369176
				def c2,0,0,0,0.215053763				
				
				tex t0
				tex t1
				tex t2

				mul r0, t0, c2.a
				mad r0, t1, c1.a, r0
				mad r0, t2, c0.a, r0
			
			endShaderSource

	end	
		

enddef




# sampling from the original image, only let "really bright" stuff through.
define FirstSideGaussianPixelShaderScaled()

	shaderProgram -target pixelProgram -method assemble
		
			shaderSource
				ps_1_1

				def c0,0,0,0,0.025089606
				def c1,0,0,0,0.143369176
				def c2,0,0,0,0.215053763
				def c3,0,0,0,0.23297491
            
            
				tex t0   ;  3 pixels to the 'left'
				tex t1
				tex t2
				tex t3   ; the center of the filter.

				mul r0, t0, c0.a
				mad r0, t1, c1.a, r0
				mad r0, t2, c2.a, r0
				mad r0, t3, c3.a, r0
			
            mul r0, r0, r0 ; pow(2)
			endShaderSource

	end	
		

enddef


# only 3 samples on this pass
define LastSideGaussianPixelShaderScaled()

	shaderProgram -target pixelProgram -method assemble
		
			shaderSource
				ps_1_1
				
				def c0,0,0,0,0.025089606
				def c1,0,0,0,0.143369176
				def c2,0,0,0,0.215053763				
				
				tex t0
				tex t1
				tex t2

				mul r0, t0, c2.a
				mad r0, t1, c1.a, r0
				mad r0, t2, c0.a, r0
            
			   mul r0, r0, r0 ; pow(2)
			endShaderSource

	end	
		

enddef







define DX8GaussianFilter()

	pass
		renderClipSpaceRect
		renderTarget "bloomB" -fixed (256,256) -bppHint 32 -alphaBitsHint 8 -clearColor (0,0,0,0) -allocateDepthBuffer false
		depthTest false -enableDepthWrite false

		create GenericFilterVertexShader(0 256 1 1 0 0 1 1 0 0)
	
		create FirstSideGaussianPixelShader()		
	
		sampler 0
			texture "bloomA"
			textureFilterHint point point
		end
		sampler 1
			texture "bloomA"
			textureFilterHint point point
		end
		sampler 2
			texture "bloomA"
			textureFilterHint point point
		end
		sampler 3
			texture "bloomA"
			textureFilterHint point point
		end
		
	end

	# 'right side', add to previous pass
	pass
		renderClipSpaceRect
		renderTarget "bloomB"
		alphaBlend srcFactor(one) add dstFactor(one)
		depthTest false -enableDepthWrite false

		create GenericFilterVertexShader(1 256 1 1 0 0 1 1 0 0)
	
		create LastSideGaussianPixelShader()
				
		sampler 0
			texture "bloomA"
			textureFilterHint point point

		end
		sampler 1
			texture "bloomA"
			textureFilterHint point point
		end
		sampler 2
			texture "bloomA"
			textureFilterHint point point
		end
		
	end
	
	
	# top:  emit directly to outbound buffer
	pass
		renderClipSpaceRect
		renderTarget "bloomFinal"  -fixed (256,256) -bppHint 32 -alphaBitsHint 8 -clearColor (0,0,0,0) -allocateDepthBuffer false
		
		depthTest false -enableDepthWrite false

		create GenericFilterVertexShader(2 256 1 1 0 0 1 1 0 0)
	
		create FirstSideGaussianPixelShader()		
	
		sampler 0
			texture "bloomB"
			textureFilterHint point point
		end
		sampler 1
			texture "bloomB"
			textureFilterHint point point
		end
		sampler 2
			texture "bloomB"
			textureFilterHint point point
		end
		sampler 3
			texture "bloomB"
			textureFilterHint point point
		end
		
	end
	
	# bottom:  emit directly to outbound buffer.
	pass
	
		renderClipSpaceRect
		renderTarget "bloomFinal"
		alphaBlend srcFactor(one) add dstFactor(one)
		depthTest false -enableDepthWrite false
		
		create GenericFilterVertexShader(3 256 1 1 0 0 1 1 0 0)
	
		create LastSideGaussianPixelShader()
				
		sampler 0
			texture "bloomB"
			textureFilterHint point point
		end
		
		sampler 1
			texture "bloomB"
			textureFilterHint point point
		end
		
		sampler 2
			texture "bloomB"
			textureFilterHint point point
		end
		
	end
	
	
	
	pass
	
		renderClipSpaceRect
		renderTarget viewerRenderTarget
		alphaBlend srcFactor(one) add dstFactor(invSrcColor)
		depthTest false -enableDepthWrite false
		
		create PassThroughVertexShader()
	
		shaderProgram -target pixelProgram -method assemble
			shaderSource
				ps_1_1
				tex t0
				mov r0, t0
			endShaderSource
		end
				
		sampler 0
			texture "bloomFinal"
		end
	
	end
	
	
enddef



# what I want to do is take a portion of the scratch buffer, not the whole thing, so I can reuse it.


define DX8WideBoxFilter(sourceBuffer scratchBuffer finalBuffer size)

   
	pass
		renderClipSpaceRect
		renderTarget "&{scratchBuffer}" #-fixed (&size, &size) -bppHint 32 -alphaBitsHint 8 -clearColor (0,0,0,0) -allocateDepthBuffer false
		depthTest false -enableDepthWrite false

      seti doubleSize (&size * 2)
      
		create GenericFilterVertexShader(0 &size 0.5 0.5 0 0 1 1 0 0)   # only write 1/2 the image, but sample the entire texture space.
	
		create FirstBoxFilterPixelShader()		
	
		sampler 0
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 1
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 2
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 3
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		
	end
   

	# 'right side', add to previous pass
	pass
		renderClipSpaceRect
		
      renderTarget "&{scratchBuffer}"
      
		alphaBlend srcFactor(one) add dstFactor(one)
		depthTest false -enableDepthWrite false

		create GenericFilterVertexShader(1 &size 0.5 0.5 0 0 1 1 0 0)
	
		create LastBoxFilterPixelShader()
				
		sampler 0
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 1
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 2
			texture "&{sourceBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		
	end
	
   #<
   pass
		renderClipSpaceRect
		renderTarget "&{finalBuffer}"  #-fixed (&size, &size) -bppHint 32 -alphaBitsHint 8 -clearColor (0,0,0,0) -allocateDepthBuffer false
		
		depthTest false -enableDepthWrite false
      
      # Image scales, Image Offset,   sampleScale Sample Offset
      create PassThroughVertexShader2(1 1 0 0  0.5 0.5 0 0.5)
      
      shaderProgram -target pixelProgram -method assemble
         shaderSource
            ps_1_1
            tex t0
            mov r0,t0
         endShaderSource
      end
      
      sampler 0
         texture "&{scratchBuffer}"
  			#textureFilterHint point point
         textureAddressing clamp clamp clamp
      end
      
   end
   #>
   
   
	
	# top:  emit directly to outbound buffer
	pass
		renderClipSpaceRect
		renderTarget "&{finalBuffer}"  #-fixed (&size, &size) -bppHint 32 -alphaBitsHint 8 -clearColor (0,0,0,0) -allocateDepthBuffer false
		
		depthTest false -enableDepthWrite false

		create GenericFilterVertexShader(2 &size 0.5 0.5 0 0 0.5 0.5 0 0.5)  # sample half, write half
	
		create FirstBoxFilterPixelShader()		
	
		sampler 0
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 1
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 2
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		sampler 3
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		
	end
	
	# bottom:  emit directly to outbound buffer.
	pass
	
		renderClipSpaceRect
		renderTarget "&{finalBuffer}"
		alphaBlend srcFactor(one) add dstFactor(one)
		depthTest false -enableDepthWrite false
		
		create GenericFilterVertexShader(3 &size 0.5 0.5 0 0 0.5 0.5 0 0.5 )
	
		create LastBoxFilterPixelShader()
				
		sampler 0
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		
		sampler 1
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		
		sampler 2
			texture "&{scratchBuffer}"
			#textureFilterHint point point
         textureAddressing clamp clamp clamp
		end
		
	end
	
   
enddef

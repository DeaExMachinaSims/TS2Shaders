vertexfragment CreateCompositeSkinningMatrixFourWayPacked1_1 = 
asm_fragment
{

// USES: temp0, temp1, temp2, temp3
// OUTPUTS:  temp5, temp6, temp7
// INPUT: constants and inputs.

// 36 Slots

	vs_1_1

	mul r_temp3, v_BLENDINDICES, c_helperConstant2.yyyy
	
	mov a0.x, r_temp3.x
	// ***** MATRIX 1 ******
	
	dp4 r_temp1.w, c_helperConstant1.yyyz, v_BLENDWEIGHT

	mul r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.x
	mul r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.x

	mov r_temp1.xyz, c_poseDataRow1[a0.x]						// preload to defeat constant limit
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	    // Cross step 1
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2  // cross step 2
	mul r_temp7.xyz, r_temp2, v_BLENDWEIGHT.x					// weight this vector.
	mul r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.x   // start on translation blending.


	// ***** MATRIX 2 ******

	mov a0.x, r_temp3.y
	mad r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.y, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.y, r_temp6
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.y, r_temp7
	
	mad r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.y, r_temp0

	// ***** MATRIX 3 ******

	mov a0.x, r_temp3.z
	mad r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.z, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.z, r_temp6
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.z, r_temp7
	
	mad r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.z, r_temp0
	
	
	// ***** MATRIX 4 ******

	mov a0.x, r_temp3.w
	mad r_temp5.xyz, c_poseDataRow1[a0.x], r_temp1.w, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], r_temp1.w, r_temp6

	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2

	mad r_temp7.xyz, r_temp2, r_temp1.w,  r_temp7

	mad r_temp5.w, c_poseTranslation[a0.x].x, r_temp1.w, r_temp0.x
	mad r_temp6.w, c_poseTranslation[a0.x].y, r_temp1.w, r_temp0.y
	mad r_temp7.w, c_poseTranslation[a0.x].z, r_temp1.w, r_temp0.z


};




vertexfragment CreateCompositeSkinningMatrixFourWayPackedIndexAsColor1_1 = 
asm_fragment
{

// USES: temp0, temp1, temp2, temp3
// OUTPUTS:  temp5, temp6, temp7
// INPUT: constants and inputs.

// 36 Slots

	vs_1_1

	# for GF3/4, without UBYTE4 support, I have to change 0->1 into 0->255) AND swizzle, since it was a color.
	mul r_temp3, v_BLENDINDICES.zyxw, c_helperConstant1.xxxx
	
	mov a0.x, r_temp3.x
	// ***** MATRIX 1 ******
	
	dp4 r_temp1.w, c_helperConstant1.yyyz, v_BLENDWEIGHT

	mul r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.x
	mul r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.x

	mov r_temp1.xyz, c_poseDataRow1[a0.x]						// preload to defeat constant limit
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	    // Cross step 1
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2  // cross step 2
	mul r_temp7.xyz, r_temp2, v_BLENDWEIGHT.x					// weight this vector.
	mul r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.x   // start on translation blending.


	// ***** MATRIX 2 ******

	mov a0.x, r_temp3.y
	mad r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.y, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.y, r_temp6
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.y, r_temp7
	
	mad r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.y, r_temp0

	// ***** MATRIX 3 ******

	mov a0.x, r_temp3.z
	mad r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.z, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.z, r_temp6
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.z, r_temp7
	
	mad r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.z, r_temp0
	
	
	// ***** MATRIX 4 ******

	mov a0.x, r_temp3.w
	mad r_temp5.xyz, c_poseDataRow1[a0.x], r_temp1.w, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], r_temp1.w, r_temp6

	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2

	mad r_temp7.xyz, r_temp2, r_temp1.w,  r_temp7

	mad r_temp5.w, c_poseTranslation[a0.x].x, r_temp1.w, r_temp0.x
	mad r_temp6.w, c_poseTranslation[a0.x].y, r_temp1.w, r_temp0.y
	mad r_temp7.w, c_poseTranslation[a0.x].z, r_temp1.w, r_temp0.z


};




// Optimized for 2 bone cases (another common case)



 
vertexfragment CreateCompositeSkinningMatrixTwoWayPacked1_1 = 
asm_fragment
{

// USES: temp0, temp1, temp2, temp3
// OUTPUTS:  temp5, temp6, temp7
// INPUT: constants and inputs.

// 36 Slots

	vs_1_1

	mul r_temp3, v_BLENDINDICES, c_helperConstant2.yyyy
	
	mov a0.x, r_temp3.x
	// ***** MATRIX 1 ******
	
	dp4 r_temp1.w, c_helperConstant1.yyyz, v_BLENDWEIGHT

	mul r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.x
	mul r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.x

	mov r_temp1.xyz, c_poseDataRow1[a0.x]						// preload to defeat constant limit
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	    // Cross step 1
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2  // cross step 2
	mul r_temp7.xyz, r_temp2, v_BLENDWEIGHT.x					// weight this vector.
	mul r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.x   // start on translation blending.


	// ***** MATRIX 2 ******

	mov a0.x, r_temp3.y
	mad r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.y, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.y, r_temp6
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.y, r_temp7
	
	mad r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.y, r_temp0

// move position into 4th column of 4x3 matrix

   mov r_temp5.w, r_temp0.x
   mov r_temp6.w, r_temp0.y
   mov r_temp7.w, r_temp0.z
   

};




vertexfragment CreateCompositeSkinningMatrixTwoWayPackedIndexAsColor1_1 = 
asm_fragment
{

// USES: temp0, temp1, temp2, temp3
// OUTPUTS:  temp5, temp6, temp7
// INPUT: constants and inputs.

// 36 Slots

	vs_1_1

	# for GF3/4, without UBYTE4 support, I have to change 0->1 into 0->255) AND swizzle, since it was a color.
	mul r_temp3, v_BLENDINDICES.zyxw, c_helperConstant1.xxxx
	
	mov a0.x, r_temp3.x
	// ***** MATRIX 1 ******
	
	dp4 r_temp1.w, c_helperConstant1.yyyz, v_BLENDWEIGHT

	mul r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.x
	mul r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.x

	mov r_temp1.xyz, c_poseDataRow1[a0.x]						// preload to defeat constant limit
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	    // Cross step 1
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2  // cross step 2
	mul r_temp7.xyz, r_temp2, v_BLENDWEIGHT.x					// weight this vector.
	mul r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.x   // start on translation blending.


	// ***** MATRIX 2 ******

	mov a0.x, r_temp3.y
	mad r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.y, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.y, r_temp6
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	mul	r_temp2.xyz,  r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp2.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp2
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.y, r_temp7
	
	mad r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.y, r_temp0
   
   // move position into 4th column of 4x3 matrix
   
   mov r_temp5.w, r_temp0.x
   mov r_temp6.w, r_temp0.y
   mov r_temp7.w, r_temp0.z
   

};






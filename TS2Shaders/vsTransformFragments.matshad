vertexfragment CreateCompositeSkinningMatrixSingleBonePacked1_1 = 
asm_fragment
{

	vs_1_1

	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	
	mov a0.x, r_temp0
	mov r_temp5.xyz, c_poseDataRow1[a0.x]
	mov r_temp6.xyz, c_poseDataRow2[a0.x]
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]

	mul	r_temp7.xyz, r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp7.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp7

	//  merge in the translation
	mov r_temp5.w, c_poseTranslation[a0.x].x
	mov r_temp6.w, c_poseTranslation[a0.x].y
	mov r_temp7.w, c_poseTranslation[a0.x].z	
	
	
};


vertexfragment CreateCompositeSkinningMatrixSingleBonePackedIndexAsColor1_1 = 
asm_fragment
{

	vs_1_1

	mul r_temp0, v_BLENDINDICES.zyxw, c_helperConstant1.xxxx
	
	mov a0.x, r_temp0
	mov r_temp5.xyz, c_poseDataRow1[a0.x]
	mov r_temp6.xyz, c_poseDataRow2[a0.x]
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]

	mul	r_temp7.xyz, r_temp1.yzx, c_poseDataRow2[a0.x].zxy	
	mad	r_temp7.xyz, -r_temp1.zxy, c_poseDataRow2[a0.x].yzx,	r_temp7

	//  merge in the translation
	mov r_temp5.w, c_poseTranslation[a0.x].x
	mov r_temp6.w, c_poseTranslation[a0.x].y
	mov r_temp7.w, c_poseTranslation[a0.x].z	
	
	
};

vertexfragment SkinNormalWithCompositeMatrix1_1 = 
asm_fragment
{
	vs_1_1
	
	//INPUTS:  ObjectSpace Normal: R11  CompositeMatrix r5,r6,r7
	//OUTPUTS: Normalized, Camera normal: r9
	//USES: r0
	
	
	dp3 r_temp0.x, r_temp11, r_temp5
	dp3 r_temp0.y, r_temp11, r_temp6
	dp3 r_temp0.z, r_temp11, r_temp7
	
	dp3 r_temp0.w, r_temp0, r_temp0     // Squared dist
	rsq r_temp0.w, r_temp0.w			// 1/sqrt
	mul r_temp9.xyz, r_temp0, r_temp0.w // normalize.
	
};


vertexfragment TransformTangentsToCameraSpaceNoSkinning1_1 =
asm_fragment
{
	vs_1_1

// transform normal	
	m3x3 r_temp11.xyz, v_TANGENT, c_objectToCameraSpaceMatrix

// assure orthogonal binormal in camera space (do a cross product)
	mul	r_temp10.xyz, r_temp11.yzx, r_temp9.zxy	
	mad	r_temp10.xyz, -r_temp11.zxy, r_temp9.yzx,	r_temp10

};


vertexfragment TransformTangentsToCameraSpaceWithCompositeMatrix1_1 =
asm_fragment
{
	vs_1_1

	dp3 r_temp11.x, v_TANGENT, r_temp5
	dp3 r_temp11.y, v_TANGENT, r_temp6
	dp3 r_temp11.z, v_TANGENT, r_temp7
		
	// cross camera space normal and cameraspace tangent to get binormal.
	mul	r_temp10.xyz, r_temp11.yzx, r_temp9.zxy	
	mad	r_temp10.xyz, -r_temp11.zxy, r_temp9.yzx,	r_temp10
};




endShaderSource

enddef







define TransformFragments(skinFlag singleBone swvsFlag morphFlag positionMorphCount normalMorphCount normalFlag shaderVersion)
   #trace "$currentMaterialName : &morphFlag : &positionMorphCount : $ubyte4Supported : &normalFlag : &normalMorphCount : &skinFlag : &singleBone : $bonesPerVertex" 
	
	if (&morphFlag and &positionMorphCount)

		if ($ubyte4Supported)

			if (&positionMorphCount = 1)
				shaderFragment MorphOnePositionTarget&{shaderVersion}
			endif
			if (&positionMorphCount = 2)
				shaderFragment MorphTwoPositionTargets&{shaderVersion}
			endif
			if (&positionMorphCount = 3)
				shaderFragment MorphThreePositionTargets&{shaderVersion}
			endif
			if (&positionMorphCount = 4)
				shaderFragment MorphFourPositionTargets&{shaderVersion}
			endif
			
			if (&normalFlag)
				if (&normalMorphCount = 1)
					shaderFragment MorphOneNormalTarget&{shaderVersion}
				endif
				if (&normalMorphCount = 2)
					shaderFragment MorphTwoNormalTargets&{shaderVersion}
				endif
				if (&normalMorphCount = 3)
					shaderFragment MorphThreeNormalTargets&{shaderVersion}
				endif
				if (&normalMorphCount = 4)
					shaderFragment MorphFourNormalTargets&{shaderVersion}
				endif
				if (&normalMorphCount = 0)
					shaderFragment NoNormalMorph&{shaderVersion}
				endif
			endif
		else   # no UBYTE4 support, use color-to-index code instead.
			if (&positionMorphCount = 1)
				shaderFragment MorphOnePositionTargetIndexAsColor&{shaderVersion}
			endif
			if (&positionMorphCount = 2)
				shaderFragment MorphTwoPositionTargetsIndexAsColor&{shaderVersion}
			endif
			if (&positionMorphCount = 3)
				shaderFragment MorphThreePositionTargetsIndexAsColor&{shaderVersion}
			endif
			if (&positionMorphCount = 4)
				shaderFragment MorphFourPositionTargetsIndexAsColor&{shaderVersion}
			endif
			
			if (&normalFlag)
			
				if (&normalMorphCount = 1)
					shaderFragment MorphOneNormalTargetIndexAsColor&{shaderVersion}
				endif
				if (&normalMorphCount = 2)
					shaderFragment MorphTwoNormalTargetsIndexAsColor&{shaderVersion}
				endif
				if (&normalMorphCount = 3)
					shaderFragment MorphThreeNormalTargetsIndexAsColor&{shaderVersion}
				endif
				if (&normalMorphCount = 4)
					shaderFragment MorphFourNormalTargetsIndexAsColor&{shaderVersion}
				endif
				
				if (&normalMorphCount = 0)
					shaderFragment NoNormalMorph&{shaderVersion}
				endif
			endif
		
		endif
		
				
	else
		shaderFragment NoMorphing&{shaderVersion}
	endif

	
	if (&skinFlag)

		# if single bone, I can optimize this case for most objects in the game.
		
		if (&singleBone)
		
         #trace "$currentMaterialName  only has one bone per vertex max, using faster case"
      
			if (&swvsFlag)
				shaderFragment SkinPositionSingleBoneUnpacked&{shaderVersion}

				# for now, assume reduce bone weights also means no bumpmapping
				
				if (&normalFlag)
					shaderFragment SkinNormalSingleBoneUnpacked&{shaderVersion}
				endif
				
			else
			
				if ($ubyte4Supported)
					shaderFragment CreateCompositeSkinningMatrixSingleBonePacked&{shaderVersion}
				else
					shaderFragment CreateCompositeSkinningMatrixSingleBonePackedIndexAsColor&{shaderVersion}
				endif
		
				shaderFragment SkinPositionWithCompositeMatrix&{shaderVersion}
				
				if (&normalFlag)
					shaderFragment SkinNormalWithCompositeMatrix&{shaderVersion}
				endif
			
			endif
				
			
					
			
		else
				
			if (&swvsFlag)
            if ($bonesPerVertex = 2)
               shaderFragment CreateCompositeSkinningMatrixTwoWayUnpacked&{shaderVersion}
            else
               shaderFragment CreateCompositeSkinningMatrixFourWayUnpacked&{shaderVersion}
            endif
			else
				
				if ($ubyte4Supported)
               if ($bonesPerVertex = 2)
                  shaderFragment CreateCompositeSkinningMatrixTwoWayPacked&{shaderVersion}
               else
                  shaderFragment CreateCompositeSkinningMatrixFourWayPacked&{shaderVersion}
      
               endif
               
				else
               if ($bonesPerVertex = 2)
                  shaderFragment CreateCompositeSkinningMatrixTwoWayPackedIndexAsColor&{shaderVersion}
               else
                   shaderFragment CreateCompositeSkinningMatrixFourWayPackedIndexAsColor&{shaderVersion}
               endif
				endif
				
			endif
			
			shaderFragment SkinPositionWithCompositeMatrix&{shaderVersion}

			if (&normalFlag)
				shaderFragment SkinNormalWithCompositeMatrix&{shaderVersion}
			endif
			
			
		endif
		
	else
	
	# no skinning cases here:
		
	
		if (&normalFlag)
			shaderFragment TransformPositionNoSkinning&{shaderVersion}
			shaderFragment TransformNormalNoSkinning&{shaderVersion}
						
		else
			
			# no lighting case, so position only.
			if (&morphFlag)
				shaderFragment TransformPositionMorphOnlyNoLighting&{shaderVersion}
			else
				shaderFragment TransformPositionRigidNoLighting&{shaderVersion}
			endif
		endif
		
	
	endif		

enddef




define VertexShaderTransformFragments()

	create VS2And3SharedTransformFragments(3_0)   #mova, cos, crs, etc
	create VS3UniqueTransformFragments()   # different output register names
	create VSSharedTransformFragments(3_0)
	
	create VS2And3SharedTransformFragments(2_0) 
	create VS2UniqueTransformFragments(2_0)
	create VSSharedTransformFragments(2_0)
	create VS1and2SharedTransformFragments(2_0)   #vs1.1 compatible, output names
	
	create VS2And3SharedTransformFragments(2_x)
	create VS2UniqueTransformFragments(2_x)
	create VSSharedTransformFragments(2_x)
	create VS1and2SharedTransformFragments(2_x)

	create VS1UniqueTransformFragments()
	create VSSharedTransformFragments(1_1)
	create VS1and2SharedTransformFragments(1_1)

enddef




define VS2And3SharedTransformFragments(versionString)

shaderSource

//############################
//# VS2 MORPHING FRAGMENTS   #
//############################

vertexfragment MorphFourPositionTargets&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov r_temp10, v_POSITION
	mova a0, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
	mad r_temp10.xyz, v_POSITION5, c_morphWeights[a0.y].www, r_temp10
	mad r_temp10.xyz, v_POSITION6, c_morphWeights[a0.z].www, r_temp10
	mad r_temp10.xyz, v_POSITION7, c_morphWeights[a0.w].www, r_temp10
};

vertexfragment MorphThreePositionTargets&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	mov r_temp10,v_POSITION
	mova a0, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
	mad r_temp10.xyz, v_POSITION5, c_morphWeights[a0.y].www, r_temp10
	mad r_temp10.xyz, v_POSITION6, c_morphWeights[a0.z].www, r_temp10
};

vertexfragment MorphTwoPositionTargets&{versionString} = 
asm_fragment
{

	vs_&{versionString}
	mov r_temp10,v_POSITION
	mova a0, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
	mad r_temp10.xyz, v_POSITION5, c_morphWeights[a0.y].www, r_temp10
};

vertexfragment MorphOnePositionTarget&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	mov r_temp10, v_POSITION
	mova a0, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
};



vertexfragment MorphFourNormalTargets&{versionString} = 
asm_fragment
{
 
 // I assume that a0 has already been loaded from the position morphs.
 // and there are no position=0, morph != 0 cases.
 
	vs_&{versionString}
	mov r_temp11,v_NORMAL
	mad r_temp11.xyz, v_NORMAL4, c_morphWeights[a0.x].www, r_temp11
	mad r_temp11.xyz, v_NORMAL5, c_morphWeights[a0.y].www, r_temp11
	mad r_temp11.xyz, v_NORMAL6, c_morphWeights[a0.z].www, r_temp11
	mad r_temp11.xyz, v_NORMAL7, c_morphWeights[a0.w].www, r_temp11
};

vertexfragment MorphThreeNormalTargets&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	mov r_temp11,v_NORMAL
	mad r_temp11.xyz, v_NORMAL4, c_morphWeights[a0.x].www, r_temp11
	mad r_temp11.xyz, v_NORMAL5, c_morphWeights[a0.y].www, r_temp11
	mad r_temp11.xyz, v_NORMAL6, c_morphWeights[a0.z].www, r_temp11
};

vertexfragment MorphTwoNormalTargets&{versionString} = 
asm_fragment
{

	vs_&{versionString}
	mov r_temp11,v_NORMAL
	mad r_temp11.xyz, v_NORMAL4, c_morphWeights[a0.x].www, r_temp11
	mad r_temp11.xyz, v_NORMAL5, c_morphWeights[a0.y].www, r_temp11
};





// ############################
// #     SKINNING FRAGMENTS   #
// ############################


vertexfragment CreateCompositeSkinningMatrixFourWayPacked&{versionString} = 
asm_fragment
{

// USES: temp0, temp1, temp2
// OUTPUTS:  temp5, temp6, temp7
// INPUT: 

	vs_&{versionString}

	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	
	mova a0, r_temp0
	
   // compute the missing wieght (only 3 weights are supplied)
   
	dp4 r_temp1.w, c_helperConstant1.yyyz, v_BLENDWEIGHT

   // load two rows
	mul r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.x
	mul r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.x
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
   // create the last row with a cross, and apply wieghting.
	crs r_temp2.xyz, r_temp1, c_PoseDataRow2[a0.x]
	mul r_temp7.xyz, r_temp2, v_BLENDWEIGHT.x
			
	mad r_temp5.xyz, c_poseDataRow1[a0.y], v_BLENDWEIGHT.y, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.y], v_BLENDWEIGHT.y, r_temp6
	mov r_temp1.xyz, c_poseDataRow1[a0.y]
	crs r_temp2.xyz, r_temp1, c_poseDataRow2[a0.y]
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.y, r_temp7

	mad r_temp5.xyz, c_poseDataRow1[a0.z], v_BLENDWEIGHT.z, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.z], v_BLENDWEIGHT.z, r_temp6
	mov r_temp1.xyz, c_poseDataRow1[a0.z]
	crs r_temp2.xyz, r_temp1, c_poseDataRow2[a0.z]
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.z, r_temp7

	mad r_temp5.xyz, c_poseDataRow1[a0.w], r_temp1.w, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.w], r_temp1.w, r_temp6
	mov r_temp1.xyz, c_poseDataRow1[a0.w]
	crs r_temp2.xyz, r_temp1, c_poseDataRow2[a0.w]
	mad r_temp7.xyz, r_temp2, r_temp1.w, r_temp7

// apply the translations.
	mul r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.x
	mad r_temp0.xyz, c_poseTranslation[a0.y], v_BLENDWEIGHT.y, r_temp0
	mad r_temp0.xyz, c_poseTranslation[a0.z], v_BLENDWEIGHT.z, r_temp0
   
// final translation using computed wieght.	
	mad r_temp5.w, c_poseTranslation[a0.w].x, r_temp1.w, r_temp0.x
	mad r_temp6.w, c_poseTranslation[a0.w].y, r_temp1.w, r_temp0.y
	mad r_temp7.w, c_poseTranslation[a0.w].z, r_temp1.w, r_temp0.z
				

};



vertexfragment CreateCompositeSkinningMatrixTwoWayPacked&{versionString} = 
asm_fragment
{

// USES: temp0, temp1, temp2
// OUTPUTS:  temp5, temp6, temp7
// INPUT: 

	vs_&{versionString}

	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	
	mova a0, r_temp0
   
	// for 2 bone case, both weights are given to us, no need to compute a 4th.

	mul r_temp5.xyz, c_poseDataRow1[a0.x], v_BLENDWEIGHT.x
	mul r_temp6.xyz, c_poseDataRow2[a0.x], v_BLENDWEIGHT.x
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	crs r_temp2.xyz, r_temp1, c_PoseDataRow2[a0.x]
	mul r_temp7.xyz, r_temp2, v_BLENDWEIGHT.x
			
	mad r_temp5.xyz, c_poseDataRow1[a0.y], v_BLENDWEIGHT.y, r_temp5
	mad r_temp6.xyz, c_poseDataRow2[a0.y], v_BLENDWEIGHT.y, r_temp6
	mov r_temp1.xyz, c_poseDataRow1[a0.y]
	crs r_temp2.xyz, r_temp1, c_poseDataRow2[a0.y]
	mad r_temp7.xyz, r_temp2, v_BLENDWEIGHT.y, r_temp7

	mul r_temp0.xyz, c_poseTranslation[a0.x], v_BLENDWEIGHT.x
	mad r_temp0.xyz, c_poseTranslation[a0.y], v_BLENDWEIGHT.y, r_temp0
	
   // expand position into skinning matrix w channels
   mov r_temp5.w, r_temp0.x
   mov r_temp6.w, r_temp0.y
   mov r_temp7.w, r_temp0.z
   

};





vertexfragment CreateCompositeSkinningMatrixSingleBonePacked&{versionString} = 
asm_fragment
{

	vs_&{versionString}

	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	
	mova a0, r_temp0
	mov r_temp5.xyz, c_poseDataRow1[a0.x]
	mov r_temp6.xyz, c_poseDataRow2[a0.x]
	
	mov r_temp1.xyz, c_poseDataRow1[a0.x]
	crs r_temp7.xyz, r_temp1, c_PoseDataRow2[a0.x]
	
	// create the composite skinning matrix.
	mov r_temp5.w, c_poseTranslation[a0.x].x
	mov r_temp6.w, c_poseTranslation[a0.x].y
	mov r_temp7.w, c_poseTranslation[a0.x].z	
	
	
};



vertexfragment CreateCompositeSkinningMatrixFourWayUnpacked&{versionString} = 
asm_fragment
{

	vs_&{versionString}
	
	mul r_realIndices, v_BLENDINDICES, c_helperConstant2.yyyy 
	mova a0, r_realIndices        

	mul r_temp5, v_BLENDWEIGHT.x, c_unpackedPoseMatrixRow1[a0.x]
	mul r_temp6, v_BLENDWEIGHT.x, c_unpackedPoseMatrixRow2[a0.x]
	mul r_temp7, v_BLENDWEIGHT.x, c_unpackedPoseMatrixRow3[a0.x]
		
	mad r_temp5, v_BLENDWEIGHT.y, c_unpackedPoseMatrixRow1[a0.y],r_temp5  
	mad r_temp6, v_BLENDWEIGHT.y, c_unpackedPoseMatrixRow2[a0.y],r_temp6  
	mad r_temp7, v_BLENDWEIGHT.y, c_unpackedPoseMatrixRow3[a0.y],r_temp7  
	
	mad r_temp5, v_BLENDWEIGHT.z, c_unpackedPoseMatrixRow1[a0.z],r_temp5  
	mad r_temp6, v_BLENDWEIGHT.z, c_unpackedPoseMatrixRow2[a0.z],r_temp6  
	mad r_temp7, v_BLENDWEIGHT.z, c_unpackedPoseMatrixRow3[a0.z],r_temp7  
	
	dp4 r_temp1.w, v_BLENDWEIGHT, c_helperConstant1.yyyz  
	mad r_temp5, r_temp1.w, c_unpackedPoseMatrixRow1[a0.w],r_temp5  
	mad r_temp6, r_temp1.w, c_unpackedPoseMatrixRow2[a0.w],r_temp6  
	mad r_temp7, r_temp1.w, c_unpackedPoseMatrixRow3[a0.w],r_temp7  

};




vertexfragment CreateCompositeSkinningMatrixTwoWayUnpacked&{versionString} = 
asm_fragment
{

	vs_&{versionString}
	
	mul r_realIndices, v_BLENDINDICES, c_helperConstant2.yyyy 
	mova a0, r_realIndices        

	mul r_temp5, v_BLENDWEIGHT.x, c_unpackedPoseMatrixRow1[a0.x]
	mul r_temp6, v_BLENDWEIGHT.x, c_unpackedPoseMatrixRow2[a0.x]
	mul r_temp7, v_BLENDWEIGHT.x, c_unpackedPoseMatrixRow3[a0.x]
		
	mad r_temp5, v_BLENDWEIGHT.y, c_unpackedPoseMatrixRow1[a0.y],r_temp5  
	mad r_temp6, v_BLENDWEIGHT.y, c_unpackedPoseMatrixRow2[a0.y],r_temp6  
	mad r_temp7, v_BLENDWEIGHT.y, c_unpackedPoseMatrixRow3[a0.y],r_temp7  
	
};



vertexfragment TransformTangentsToCameraSpaceNoSkinning&{versionString} =
asm_fragment
{
	vs_&{versionString}

// transform normal	
	m3x3 r_temp11.xyz, v_TANGENT, c_objectToCameraSpaceMatrix

// assure orthogonal binormal in camera space
	
	crs r_temp10.xyz, r_temp11, r_temp9
	

};


vertexfragment TransformTangentsToCameraSpaceWithCompositeMatrix&{versionString} =
asm_fragment
{
	vs_&{versionString}

	dp3 r_temp11.x, v_TANGENT, r_temp5
	dp3 r_temp11.y, v_TANGENT, r_temp6
	dp3 r_temp11.z, v_TANGENT, r_temp7
		
	// cross camera space normal and cameraspace tangent to get binormal.
	crs r_temp10.xyz, r_temp11, r_temp9
};




endShaderSource

enddef  # End VS2Shared Transform Fragments


#########################
# UNIQUE VS3 FRAGMENTS
#  Writes to o_POSITION, o_TEXCOORD, and o_NORMAL
##########################


define VS3UniqueTransformFragments()

shaderSource

//  3.0 fragments are for pre-process, which emit camera space coords, NOT CLIP SPACE COORDS

// support for "Reduce bone weights option" for unpacked cases, packed still uses composite matrix
vertexfragment SkinPositionSingleBoneUnpacked3_0 = 
asm_fragment
{
	vs_3_0

	mov r_temp10.w, c_helperConstant1.z
	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	mova a0, r_temp0
	m4x3 o_POSITION.xyz, r_temp10, c_unpackedPoseMatrix[a0.x]

};


vertexfragment SkinPositionWithCompositeMatrix3_0 = 
asm_fragment
{
	vs_3_0

	mov r_temp10.w, c_basics.z

	dp4 o_POSITION.x, r_temp10, r_temp5
	dp4 o_POSITION.y, r_temp10, r_temp6
	dp4 o_POSITION.z, r_temp10, r_temp7


};


vertexfragment SkinNormalWithCompositeMatrix3_0 = 
asm_fragment
{
	vs_3_0

	dp3 o_NORMAL.x, r_temp11, r_temp5
	dp3 o_NORMAL.y, r_temp11, r_temp6
	dp3 o_NORMAL.z, r_temp11, r_temp7

};

vertexfragment SkinNormalSingleBoneUnpacked3_0 = 
asm_fragment
{
	vs_3_0
   
	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	mova a0, r_temp0

	m3x3 o_NORMAL.xyz, r_temp11, c_unpackedPoseMatrix[a0.x]

};


vertexfragment TransformRigidForLighting3_0 =
asm_fragment
{
	vs_3_0

	// CS position
	//m4x3 o_POSITION.xyz, v_POSITION, c_objectToCameraSpaceMatrix
	
	// CS normal
//	m3x3 o_NORMAL.xyz, v_NORMAL, c_objectToCameraSpaceMatrix

   mov o_POSITION.xyz, v_POSITION
   mov o_NORMAL.xyz, v_NORMAL

};



vertexfragment TransformPositionNoSkinning3_0 =
asm_fragment
{
	vs_3_0
	
	mov r_temp10.w, c_helperConstant1.z
	
	//m4x3 o_POSITION.xyz, r_temp10, c_objectToCameraSpaceMatrix
   mov o_POSITION.xyz, r_temp10


};

vertexfragment TransformPositionRigidNoLighting3_0 =
asm_fragment
{
	vs_3_0
   
	// hopefully won't be called when in pre-process.

	mov o_POSITION, v_POSITION
	mov o_NORMAL, v_NORMAL

};


vertexfragment TransformPositionMorphOnlyNoLighting3_0 =
asm_fragment
{
	vs_3_0
	
	// vertex in object space still after morphing, so emit directly without transform.
	
	mov o_POSITION, r_temp10
   
   mov o_NORMAL, v_NORMAL

};

vertexfragment TransformNormalNoSkinning3_0 =
asm_fragment
{
	vs_3_0
	
	// object to clip space directly
	
	//m3x3 o_NORMAL.xyz, r_temp11, c_objectToCameraSpaceMatrix
   mov o_NORMAL.xyz, r_temp11

};

endShaderSource


enddef





define VS2UniqueTransformFragments(versionString)

shaderSource

// support for "Reduce bone weights option" for unpacked cases, packed still uses composite matrix
vertexfragment SkinPositionSingleBoneUnpacked&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov r_temp10.w, c_helperConstant1.z
	mul r_temp0, v_BLENDINDICES, c_helperConstant2.yyyy
	mova a0, r_temp0
	m4x3 r_temp8.xyz, r_temp10, c_unpackedPoseMatrix[a0.x]

	mov r_temp8.w, c_helperConstant1.z
	
	m4x4 r_temp4, r_temp8, c_cameraToClipSpaceMatrix	
	mov oPos, r_temp4
	mov oT1.xy, r_temp4.zw 
};

vertexfragment SkinNormalWithCompositeMatrix&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_temp0.x, r_temp11, r_temp5
	dp3 r_temp0.y, r_temp11, r_temp6
	dp3 r_temp0.z, r_temp11, r_temp7
	
	nrm r_temp9.xyz, r_temp0

};

endShaderSource


enddef


#################################
#  SHARED TRANSFORM FRAGMENTS   #
#################################
# no crs, nrm, mova, etc.

define VSSharedTransformFragments(versionString)

shaderSource


// ############################
// #     MORPHING FRAGMENTS   #
// ############################


vertexfragment MorphOneNormalTarget&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	mov r_temp11, v_NORMAL
	mad r_temp11.xyz, v_NORMAL4, c_morphWeights[a0.x].www, r_temp11
};


vertexfragment NoMorphing&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	mov r_temp10, v_POSITION
	mov r_temp11, v_NORMAL
};


vertexfragment NoNormalMorph&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	mov r_temp11.xyz, v_NORMAL
};



// ############################
// #     TRANSFORM FRAGMENTS   #
// ############################





// TEMP 8 = CameraSpace Position
// TEMP 9 = Camera Space normal
// TEMP 10 = morphed position / camera space binormal
// TEMP 11 = morphed normal / camera space tangent




endShaderSource

enddef  # End Shared Transform Fragments




# VS 1 & 2 'basic' fragments, with oPos, etc as outputs.

define VS1and2SharedTransformFragments(versionString)

shaderSource



vertexfragment SkinNormalSingleBoneUnpacked&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	// a0.x set up from position skinning
	m3x3 r_temp9.xyz, r_temp11, c_unpackedPoseMatrix[a0.x]
	
};




vertexfragment TransformNormalNoSkinning&{versionString} =
asm_fragment
{
	vs_&{versionString}

	m3x3 r_temp9.xyz, r_temp11, c_objectToCameraSpaceMatrix
	
};


vertexfragment SkinPositionWithCompositeMatrix&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov r_temp10.w, c_basics.z

	dp4 r_temp8.x, r_temp10, r_temp5
	dp4 r_temp8.y, r_temp10, r_temp6
	dp4 r_temp8.z, r_temp10, r_temp7
	mov r_temp8.w, c_basics.z
	
	m4x4 r_temp4, r_temp8, c_cameraToClipSpaceMatrix	
	mov oPos, r_temp4
	mov oT1.xy, r_temp4.zw 
};

vertexfragment SkinPositionWithCompositeMatrixTempStore&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov r_temp10.w, c_basics.z

	dp4 r_position.x, r_temp10, r_temp5
	dp4 r_position.y, r_temp10, r_temp6
	dp4 r_position.z, r_temp10, r_temp7
	mov r_position.w, c_basics.z
		
};


vertexfragment TransformRigidForLighting&{versionString} =
asm_fragment
{
	vs_&{versionString}

	// CS position
	m4x3 r_temp8.xyz, v_POSITION, c_objectToCameraSpaceMatrix
	mov r_temp8.w, c_basics.z
	
	// CS normal
	m3x3 r_temp9.xyz, v_NORMAL, c_objectToCameraSpaceMatrix
	mov r_temp9.w, c_basics.z

	// clip space position
	m4x4 r_temp4, r_temp8, c_cameraToClipSpaceMatrix	
	mov oPos, r_temp4
	mov oT1.xy, r_temp4.zw 	
	
	mov oT0.xy, v_TEXCOORD
	
	// inputs ready for all lighting fragments
	
};



vertexfragment TransformPositionNoSkinning&{versionString} =
asm_fragment
{
	vs_&{versionString}
	
	mov r_temp10.w, c_helperConstant1.z
	
	m4x3 r_temp8.xyz, r_temp10, c_objectToCameraSpaceMatrix

	mov r_temp8.w, c_helperConstant1.z

	m4x4 r_temp4, r_temp8, c_cameraToClipSpaceMatrix   
	mov oPos, r_temp4
	mov oT1.xy, r_temp4.zw 
};



vertexfragment TransformPositionNoSkinningTempStore&{versionString} =
asm_fragment
{
	vs_&{versionString}
	
	mov r_temp10.w, c_helperConstant1.z
	
	m4x3 r_position.xyz, r_temp10, c_objectToCameraSpaceMatrix

	mov r_position.w, c_helperConstant1.z

};





vertexfragment TransformPositionRigidNoLighting&{versionString} =
asm_fragment
{
	vs_&{versionString}
	// object to clip space directly

	m4x4 r_temp4, v_POSITION, c_objectToClipSpaceMatrix	
	mov oPos, r_temp4
	mov oT1.xy, r_temp4.zw 
};


vertexfragment TransformPositionMorphOnlyNoLighting&{versionString} =
asm_fragment
{
	vs_&{versionString}
	
	// object to clip space directly
	
	m4x4 r_temp4, r_temp10, c_objectToClipSpaceMatrix	
	mov oPos, r_temp4
	mov oT1.xy, r_temp4.zw 
};



endShaderSource


enddef

define VS1UniqueTransformFragments()

shaderSource


// #################################
// #  VS1 TRANSFORM FRAGMENTS   #
// #################################
// no crs, nrm, mova, etc. Mov for address, macro expansions, etc.




// #################################
// #    VS1 MORPHING FRAGMENTS     #
// #################################


// ###############################
// #  UBYTE4  POSITION MORPHING  #
// ###############################



vertexfragment MorphFourPositionTargets1_1 = 
asm_fragment
{
	vs_1_1
	
	mov r_temp10, v_POSITION
	mov a0.x, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
	mov a0.x, v_BLENDINDICES4.y
	mad r_temp10.xyz, v_POSITION5, c_morphWeights[a0.x].www, r_temp10
	mov a0.x, v_BLENDINDICES4.z
	mad r_temp10.xyz, v_POSITION6, c_morphWeights[a0.x].www, r_temp10
	mov a0.x, v_BLENDINDICES4.w
	mad r_temp10.xyz, v_POSITION7, c_morphWeights[a0.x].www, r_temp10
	
};

vertexfragment MorphThreePositionTargets1_1 = 
asm_fragment
{
	vs_1_1
	mov r_temp10, v_POSITION
	
	mov a0.x, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10

	mov a0.x, v_BLENDINDICES4.y
	mad r_temp10.xyz, v_POSITION5, c_morphWeights[a0.x].www, r_temp10

	mov a0.x, v_BLENDINDICES4.z
	mad r_temp10.xyz, v_POSITION6, c_morphWeights[a0.x].www, r_temp10
};

vertexfragment MorphTwoPositionTargets1_1 = 
asm_fragment
{

	vs_1_1
	mov r_temp10,v_POSITION
	mov a0.x, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
	
	mov a0.x, v_BLENDINDICES4.y
	mad r_temp10.xyz, v_POSITION5, c_morphWeights[a0.x].www, r_temp10
	
};

vertexfragment MorphOnePositionTarget1_1 = 
asm_fragment
{
	vs_1_1
	mov r_temp10, v_POSITION
	mov a0.x, v_BLENDINDICES4
	mad r_temp10.xyz, v_POSITION4, c_morphWeights[a0.x].www, r_temp10
};


// ###############################
// #  NO UBYTE4 MORPHING	     #
// ###############################


// DX8 per-pixel lighting in the 4 light case is done with 3 lights and one vertex light 
// light vector are pre-scaled to save clocks/complexity in the pixel shader.


// No normal map case, (like the faces).. Do per-pixel clamps, but no normal map)
vertexfragment PointSpotPixelDiffuseXYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	

	dp3 r_temp0.x, r_temp4, r_temp10
	dp3 r_temp0.y, r_temp4, r_temp11
	dp3 r_temp0.z, r_temp4, r_temp9     // transform to tangent space

	mul  r_temp0,  r_temp0, r_attenuation // apply attenuation factor to vector.
	mad oT1.xyz, r_temp0, c_helperConstant2.z, c_helperConstant2.z // smash signed vector into unsigned vector
	
	dp3 r_temp0.x, r_temp5, r_temp10
	dp3 r_temp0.y, r_temp5, r_temp11
	dp3 r_temp0.z, r_temp5, r_temp9     // transform to tangent space
	
	mul  r_temp0,  r_temp0, r_attenuation // apply attenuation factor to vector.
	mad oT2.xyz, r_temp0, c_helperConstant2.z, c_helperConstant2.z // smash signed vector into unsigned vector

	dp3 r_temp0.x, r_temp6, r_temp10
	dp3 r_temp0.y, r_temp6, r_temp11
	dp3 r_temp0.z, r_temp6, r_temp9     // transform to tangent space
	
	mul  r_temp0,  r_temp0, r_attenuation // apply attenuation factor to vector.
	mad oT3.xyz, r_temp0, c_helperConstant2.z, c_helperConstant2.z // smash signed vector into unsigned vector

	mov oT0.xy, v_TEXCOORD0   ; T0 = base texture
	
	dp3 r_temp0.w, r_temp7, r_temp9  // N.L light 4
	max r_temp0.w, c_basics.x, r_temp0  // assure positive
	mul r_temp0.w, r_temp0, r_attenuation // apply attenuation factors
	mul r_temp0.rgb, r_temp0.w, c_lightColors[a0.x]
	add r_temp0.rgb, r_temp0, c_ambientLightColor
	mul oD0.rgb, r_temp0, c_diffuseMaterialColor
	mov oD0.a, c_diffuseMaterialColor.w

	
	
};



vertexfragment PointSpotVertexSpecularXYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_rdotls.x, r_temp4, r_reflectionVector  // R.L light 1
	dp3 r_rdotls.y, r_temp5, r_reflectionVector
	dp3 r_rdotls.z, r_temp6, r_reflectionVector
	dp3 r_rdotls.w, r_temp7, r_reflectionVector  // R.L light 4
	
	mul r_rdotls, r_rdotls, r_attenuation // apply attenuation factors
};

vertexfragment DistantVertexSpecularXYZW&{versionString}= 

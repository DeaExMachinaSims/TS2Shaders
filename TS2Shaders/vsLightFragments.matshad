vertexfragment PointSpotAttenuationXY&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	// start attenuation
	// 1 / (1 + C * d^2)
	
	mul r_attenuation.xy, c_lightAttenuation[a0.x], r_range

// range cutoffs, compare squared distances
	sge r_temp1.xy, c_lightRanges[a0.x], r_range

	// add 1
	// two constants, so I can't use MAD here.
	add r_attenuation.xy, r_attenuation, c_basics.z
	
	// 1 / x
	rcp r_attenuation.x, r_attenuation.x
	rcp r_attenuation.y, r_attenuation.y

	// roll in range cutoffs
	mul r_attenuation.xy, r_temp1, r_attenuation
	

};


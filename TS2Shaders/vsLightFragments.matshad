	// add 1
	// two constants, so I can't use MAD here.
	add r_attenuation.yz, r_attenuation, c_basics.z
	
	// 1 / x
	rcp r_attenuation.y, r_attenuation.y
	rcp r_attenuation.z, r_attenuation.z

	// roll in range cutoffs
	mul r_attenuation.yz, r_temp1, r_attenuation
	

};



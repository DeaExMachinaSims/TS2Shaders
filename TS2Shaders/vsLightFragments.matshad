
include vsLoopLightFragments.matShad

define VertexShaderLightingFragments()


	create VS2SharedLightingFragments(2_0)
	create VS2SharedLightingFragments(2_x)
	
	create VSSharedLightingFragments(2_0)
	create VSSharedLightingFragments(2_x)
	create VSSharedLightingFragments(1_1)
	
	create VS1UniqueLightingFragments()
   create LightLoopFragments(2_0)
   
enddef




define VS2SharedLightingFragments(versionString)


shaderSource


vertexfragment ObjectSnowShader&{versionString} =
asm_fragment
{
   vs_&{versionString}   
   
   mov r_temp0, v_NORMAL
   mov oT0.x, r_temp0.zzz
   mov r_temp0, v_POSITION
   mov oT1.xy, r_temp0.xy
   mov oT2.xyz, r_temp9.xyz
   dp3 r_temp0, r_temp9, c_lightDirections[0]   
   //dp3 r_temp1, r_temp9, c_lightDirections[2]
   mul r_temp2, r_temp0, c_lightColors[0]      
   //mad oT3.xyz, r_temp1, c_lightColors[2], r_temp2
   mov oT3.xyz, r_temp2
};



vertexfragment CreateReflectionVector&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	nrm r_temp1.xyz, -r_temp8
	// 2N
	add r_temp0.xyz, r_temp9, r_temp9   
	// N.V
	dp3 r_temp0.w, r_temp9, r_temp1
	
	// 2N ( N.V) - V
	mad r_reflectionVector.xyz, r_temp0, r_temp0.w, -r_temp1
		
};



vertexfragment SetLight0Offset&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	mova a0.x, c_basics.x
};


vertexfragment SetLight1Offset&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	mova a0.x, c_basics.z
};

vertexfragment SetLight2Offset&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	mova a0.x, c_basics.w
};


vertexfragment SetLight3Offset&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	mova a0.x, c_helperConstant2.y
};

vertexfragment SetLight4Offset&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	mova a0.x, c_helperConstant1.w
};


vertexfragment CompleteVertexDiffuseAddAmbientHDR&{versionString}=
asm_fragment
{	
	vs_&{versionString}

	add r_diffuse_r2.rgb, r_diffuse_r2, c_ambientLightColor
	
	mul r_diffuse_r2.rgb, r_diffuse_r2, c_diffuseMaterialColor

	add oT2.rgb, r_diffuse_r2, c_emissiveColor

	mov oT2.a, c_diffuseMaterialColor.w
	
};


//#######
//#  SPECULAR  USING POW  #
//#######


vertexfragment VertexSpecularXYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	
	max r_rdotls, c_basics.x, r_rdotls  // assure positive
	
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	pow r_temp1.y, r_rdotls.y, c_specularMaterialColor.w
	pow r_temp1.z, r_rdotls.z, c_specularMaterialColor.w
	pow r_temp1.w, r_rdotls.w, c_specularMaterialColor.w

	add r_ndotls, r_ndotls, -c_helperConstant2.w
	slt r_ndotlClamp, -r_ndotls, c_basics.x
	mul r_temp1, r_temp1, r_ndotlClamp   # cutoff if NdotL < 0

	// without going to a 2 constant packed array for the specular Scales, (and more bind Constants as well as address register wrangling)
	// I have to combine and multiply thisway.
	
	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w
	mul r_temp1.y, r_temp1, c_lightColors[a0.x+1].w
	mul r_temp1.z, r_temp1,  c_lightColors[a0.x+2].w
	mul r_temp1.w, r_temp1, c_lightColors[a0.x+3].w
	
	mul r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x]  // complete specular for light 1
	mad r_specular_r2.rgb, r_temp1.y, c_lightColors[a0.x+1], r_specular_r2
	mad r_specular_r2.rgb, r_temp1.z, c_lightColors[a0.x+2], r_specular_r2
	mad r_specular_r2.rgb, r_temp1.w, c_lightColors[a0.x+3], r_specular_r2
		
};


vertexfragment VertexSpecularXYZ&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	

	max r_rdotls.xyz, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	pow r_temp1.y, r_rdotls.y, c_specularMaterialColor.w
	pow r_temp1.z, r_rdotls.z, c_specularMaterialColor.w
	

   add r_ndotls.xyz, r_ndotls, -c_helperConstant2.w
   slt r_ndotlClamp.xyz, -r_ndotls, c_basics.xxx 
	mul r_temp1.xyz, r_temp1, r_ndotlClamp

	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w
	mul r_temp1.y, r_temp1, c_lightColors[a0.x+1].w
	mul r_temp1.z, r_temp1, c_lightColors[a0.x+2].w

	mul r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x]  // complete specular for light 1
	mad r_specular_r2.rgb, r_temp1.y, c_lightColors[a0.x+1], r_specular_r2
	mad r_specular_r2.rgb, r_temp1.z, c_lightColors[a0.x+2], r_specular_r2

   mul oT7.xyz, r_specular_r2, c_specularMaterialColor


};



vertexfragment VertexSpecularXY&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	max r_rdotls.xy, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	pow r_temp1.y, r_rdotls.y, c_specularMaterialColor.w
	
   add r_ndotls.xy, r_ndotls, -c_helperConstant2.w

	slt r_ndotlClamp.xy, -r_ndotls, c_basics.x
	mul r_temp1.xy, r_temp1, r_ndotlClamp
	
	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w
	mul r_temp1.y, r_temp1, c_lightColors[a0.x+1].w

	mul r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x]  // complete specular for light 1
	mad r_specular_r2.rgb, r_temp1.y, c_lightColors[a0.x+1], r_specular_r2


};


vertexfragment VertexSpecularX&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	
	max r_rdotls.x, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	
   add r_ndotls.x, r_ndotls, -c_helperConstant2.w

	slt r_ndotlClamp.x, -r_ndotls, c_basics.x
	mul r_temp1.x, r_temp1, r_ndotlClamp

	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w

	mul r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x]  // complete specular for light 1
	 
		
};




vertexfragment VertexSpecularAccumulateXYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	max r_rdotls, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	pow r_temp1.y, r_rdotls.y, c_specularMaterialColor.w
	pow r_temp1.z, r_rdotls.z, c_specularMaterialColor.w
	pow r_temp1.w, r_rdotls.w, c_specularMaterialColor.w
	
   add r_ndotls, r_ndotls, -c_helperConstant2.w

	slt r_ndotlClamp.xyzw, -r_ndotls, c_basics.x
	mul r_temp1.xyzw, r_temp1, r_ndotlClamp
	
//	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w
//	mul r_temp1.y, r_temp1, c_lightColors[a0.x+1].w
//	mul r_temp1.z, r_temp1, c_lightColors[a0.x+2].w
//	mul r_temp1.w, r_temp1, c_lightColors[a0.x+3].w

	mad r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x], r_specular_r2  // complete specular for light 1
	mad r_specular_r2.rgb, r_temp1.y, c_lightColors[a0.x+1], r_specular_r2
	mad r_specular_r2.rgb, r_temp1.z, c_lightColors[a0.x+2], r_specular_r2
	mad r_specular_r2.rgb, r_temp1.w, c_lightColors[a0.x+3], r_specular_r2
		
};


vertexfragment VertexSpecularAccumulateXYZ&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	max r_rdotls.xyz, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	pow r_temp1.y, r_rdotls.y, c_specularMaterialColor.w
	pow r_temp1.z, r_rdotls.z, c_specularMaterialColor.w
	
   add r_ndotls.xyz, r_ndotls, -c_helperConstant2.w
	slt r_ndotlClamp.xyz, -r_ndotls, c_basics.x
	mul r_temp1.xyz, r_temp1, r_ndotlClamp
	
	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w
	mul r_temp1.y, r_temp1, c_lightColors[a0.x+1].w
	mul r_temp1.z, r_temp1, c_lightColors[a0.x+2].w

	mad r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x] , r_specular_r2 // complete specular for light 1
	mad r_specular_r2.rgb, r_temp1.y, c_lightColors[a0.x+1], r_specular_r2
	mad r_specular_r2.rgb, r_temp1.z, c_lightColors[a0.x+2], r_specular_r2
	
	
};



vertexfragment VertexSpecularAccumulateXY&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	max r_rdotls.xy, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w
	pow r_temp1.y, r_rdotls.y, c_specularMaterialColor.w
	
   add r_ndotls.xy, r_ndotls, -c_helperConstant2.w
	slt r_ndotlClamp.xy, -r_ndotls, c_basics.x
	mul r_temp1.xy, r_temp1, r_ndotlClamp

	mul r_temp1.x, r_temp1, c_lightColors[a0.x].w

   mul r_temp1.y, r_temp1, c_lightColors[a0.x+1].w

	
	mad r_specular_r2.rgb, r_temp1.x, c_lightColors[a0.x], r_specular_r2 // complete specular for light 1
	mad r_specular_r2.rgb, r_temp1.y, c_lightColors[a0.x+1], r_specular_r2


};

vertexfragment VertexSpecularAccumulateX&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	max r_rdotls.x, c_basics.x, r_rdotls  // assure positive
		
	pow r_temp1.x, r_rdotls.x, c_specularMaterialColor.w  // apply specular shinyness

	add r_ndotls.x, r_ndotls, -c_helperConstant2.w   // fudge factor
	slt r_ndotlClamp.x, -r_ndotls, c_basics.x     // test for N.L > 0
	mul r_temp1.x, r_temp1, r_ndotlClamp        // kill any < 0
	
   mul r_temp1.x, r_temp1, c_lightColors[a0.x].www  // apply relative specular scale
   mad r_specular_r2.rgb, r_temp1.xxx, c_lightColors[a0.x], r_specular_r2
   
   //mul r_thisSpec.rgb, r_temp1.xxx, c_lightColors[a0.x]  // apply light color.


  // add r_specular_r2.rgb, r_specular_r2, r_thisSpec

//   mov r_blah.rgb, r_specular_r2
   
//   mov r_specular_r2.rgb, r_thisSpec
   
//   add r_blah.rgb, r_specular_r2, r_blah
 
 //  mov r_specular_r2.rgb, r_blah

};


endShaderSource

enddef




define VSSharedLightingFragments(versionString)

########
#  SHARED LIGHTING FRAGMENTS #
########


# Lighting has been re-unified.
# DX8 will do 4 lights per pass. (Diffuse first, then specular)
# DX9 will have 2 'internal' passes of lights that will accumulate and emit a final color in one pass


shaderSource

vertexfragment  ZeroHDROutputs&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
   mov oT2.xyz, c_basics.x
   mov oT3.xyz, c_basics.x

};


// one single monochrome light, with it's results going to the texture coordinate instead of a color.

vertexfragment  CelShadingLight&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_ndotls.x, c_lightDirections, r_temp9
	
	max oT0.x, r_ndotls.x, c_basics.x
	mov oT0.y, c_basics.x
};

// special case, where the 'V' coordinate is a selector for the color or ramp to choose.
// the selector is the alpha value from the vertex color.

vertexfragment  CelShadingVertexAlphaToVCoordinate&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov oT0.y, v_COLOR0.w

};



// to maintain compatibility, no-lighting cases will go through the 8-bit path, the PS2 code will always add D0. HDR cases will write black to them
vertexfragment NoLighting&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	// write WHITE, if lighting is off.
	mov oD0, c_basics.z 
	mov oD1, c_basics.x	// black to specular
};


vertexfragment NoLightingHDR&{versionString} = 
asm_fragment
{
	vs_&{versionString}
	
	// write WHITE, if lighting is off.
	mov oT2, c_helperConstant1.z // c_diffuseMaterialColor
	mov oT3, c_basics.x	
};


vertexfragment AmbientLighting&{versionString} = 
asm_fragment
{
	vs_&{versionString}
		
	mov r_ambient, c_ambientLightColor
// yes yes, a constant * constant is lame, but since ambient comes from the engine, not a matshad, I have no way of setting this value!	
	mul r_ambient, r_ambient, c_diffuseMaterialColor
	mul oD0.xyz, r_ambient, c_basics.y  // half lights, so PS can do _x2
	mov oD0.w, c_diffuseMaterialColor.w
	mov oD1, c_basics.x	
	
};


vertexfragment AmbientLightingVertexColorMaterial&{versionString} = 
asm_fragment
{
	vs_&{versionString}
		
	mul r_ambient, c_ambientLightColor, v_COLOR0
	
	mul r_ambient.rgb, r_ambient, c_diffuseMaterialColor
	
	mov oD0.rgb, r_ambient
	//mul oD0.rgb, r_ambient, c_basics.y
	
	mov oD0.a, v_COLOR0.w // copy vertex color alpha straight out.

	mov oD1, c_basics.x	
	
};



vertexfragment CopyVertexAlphaToDiffuse&{versionString} = 
asm_fragment
{
	vs_&{versionString}

	mov oD0.w, v_COLOR0
		
};



vertexfragment AmbientLightingHDR&{versionString} = 
asm_fragment
{
	vs_&{versionString}
		
	mov r_ambient, c_ambientLightColor
// yes yes, a constant * constant is lame, but since ambient comes from the engine, not a matshad, I have no way of setting this value!	
	mul oT2, r_ambient, c_diffuseMaterialColor
	mov oT3, c_basics.x	
	
};


vertexfragment AmbientLightingVertexColorMaterialHDR&{versionString} = 
asm_fragment
{
	vs_&{versionString}
		
	mul oT2.xyz, c_ambientLightColor, v_COLOR
	mov oT2.w, v_COLOR
	mov oT3, c_basics.x	
	
};


vertexfragment PointSpotLightVectorsXYZW&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp4.xyz, c_lightPositions[a0.x], r_temp8         // light vector generation
	sub r_temp5.xyz, c_lightPositions[a0.x+1], r_temp8
	sub r_temp6.xyz, c_lightPositions[a0.x+2], r_temp8
	sub r_temp7.xyz, c_lightPositions[a0.x+3], r_temp8

	dp3 r_range.x, r_temp4, r_temp4       // compute squared length of light vector
	dp3 r_range.y, r_temp5, r_temp5
	dp3 r_range.z, r_temp6, r_temp6
	dp3 r_range.w, r_temp7, r_temp7

	rsq r_temp4.w, r_range.x          // for normalization.
	rsq r_temp5.w, r_range.y
	rsq r_temp6.w, r_range.z
	rsq r_temp7.w, r_range.w

	// normalize light vectors.
	mul r_temp4.xyz, r_temp4, r_temp4.w
	mul r_temp5.xyz, r_temp5, r_temp5.w
	mul r_temp6.xyz, r_temp6, r_temp6.w
	mul r_temp7.xyz, r_temp7, r_temp7.w
};



vertexfragment PointSpotAttenuationXYZW&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	// start attenuation
	// 1 / (1 + C * d^2)
	
	mul r_attenuation, c_lightAttenuation[a0.x], r_range

// range cutoffs, compare squared distances
	sge r_temp1, c_lightRanges[a0.x], r_range

	// add 1
	// two constants, so I can't use MAD here.
	add r_attenuation, r_attenuation, c_helperConstant1.z
	
	// 1 / x
	rcp r_attenuation.x, r_attenuation.x
	rcp r_attenuation.y, r_attenuation.y
	rcp r_attenuation.z, r_attenuation.z
	rcp r_attenuation.w, r_attenuation.w

	// roll in range cutoffs
	mul r_attenuation, r_temp1, r_attenuation
	

};



vertexfragment PointSpotLightVectorsXYZ&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp4.xyz, c_lightPositions[a0.x], r_temp8         // light vector generation
	sub r_temp5.xyz, c_lightPositions[a0.x+1], r_temp8
	sub r_temp6.xyz, c_lightPositions[a0.x+2], r_temp8

	dp3 r_range.x, r_temp4, r_temp4       // compute squared length of light vector
	dp3 r_range.y, r_temp5, r_temp5
	dp3 r_range.z, r_temp6, r_temp6

	rsq r_temp4.w, r_range.x          // for normalization.
	rsq r_temp5.w, r_range.y
	rsq r_temp6.w, r_range.z


	// normalize light vectors.
	mul r_temp4.xyz, r_temp4, r_temp4.w
	mul r_temp5.xyz, r_temp5, r_temp5.w
	mul r_temp6.xyz, r_temp6, r_temp6.w
};

vertexfragment PointSpotLightVectorsYZW&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp5.xyz, c_lightPositions[a0.x+1], r_temp8         // light vector generation
	sub r_temp6.xyz, c_lightPositions[a0.x+2], r_temp8
	sub r_temp7.xyz, c_lightPositions[a0.x+3], r_temp8

	dp3 r_range.y, r_temp5, r_temp5       // compute squared length of light vector
	dp3 r_range.z, r_temp6, r_temp6
	dp3 r_range.w, r_temp7, r_temp7

	rsq r_temp5.w, r_range.y          // for normalization.
	rsq r_temp6.w, r_range.z
	rsq r_temp7.w, r_range.w


	// normalize light vectors.
	mul r_temp5.xyz, r_temp5, r_temp5.w
	mul r_temp6.xyz, r_temp6, r_temp6.w
	mul r_temp7.xyz, r_temp7, r_temp7.w
};


vertexfragment PointSpotAttenuationXYZ&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	// start attenuation
	// 1 / (1 + C * d^2)
	
	mul r_attenuation.xyz, c_lightAttenuation[a0.x], r_range

// range cutoffs, compare squared distances
	sge r_temp1.xyz, c_lightRanges[a0.x], r_range

	// add 1
	// two constants, so I can't use MAD here.
	add r_attenuation.xyz, r_attenuation, c_basics.z
	
	// 1 / x
	rcp r_attenuation.x, r_attenuation.x
	rcp r_attenuation.y, r_attenuation.y
	rcp r_attenuation.z, r_attenuation.z

	// roll in range cutoffs
	mul r_attenuation.xyz, r_temp1, r_attenuation
	

};


vertexfragment PointSpotAttenuationYZW&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	// start attenuation
	// 1 / (1 + C * d^2)
	
	mul r_attenuation.yzw, c_lightAttenuation[a0.x], r_range

// range cutoffs, compare squared distances
	sge r_temp1.yzw, c_lightRanges[a0.x], r_range

	// add 1
	// two constants, so I can't use MAD here.
	add r_attenuation.yzw, r_attenuation, c_basics.z
	
	// 1 / x
	rcp r_attenuation.y, r_attenuation.y
	rcp r_attenuation.z, r_attenuation.z
	rcp r_attenuation.w, r_attenuation.w

	// roll in range cutoffs
	mul r_attenuation.yzw, r_temp1, r_attenuation
	
};




vertexfragment PointSpotLightVectorsXY&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp4.xyz, c_lightPositions[a0.x], r_temp8         // light vector generation
	sub r_temp5.xyz, c_lightPositions[a0.x+1], r_temp8

	dp3 r_range.x, r_temp4, r_temp4       // compute squared length of light vector
	dp3 r_range.y, r_temp5, r_temp5

	rsq r_temp4.w, r_range.x          // for normalization.
	rsq r_temp5.w, r_range.y

	// normalize light vectors.
	mul r_temp4.xyz, r_temp4, r_temp4.w
	mul r_temp5.xyz, r_temp5, r_temp5.w
	
};



vertexfragment PointSpotLightVectorsYZ&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp5.xyz, c_lightPositions[a0.x+1], r_temp8         // light vector generation
	sub r_temp6.xyz, c_lightPositions[a0.x+2], r_temp8

	dp3 r_range.y, r_temp5, r_temp5       // compute squared length of light vector
	dp3 r_range.z, r_temp6, r_temp6

	rsq r_temp5.w, r_range.y          // for normalization.
	rsq r_temp6.w, r_range.z

	// normalize light vectors.
	mul r_temp5.xyz, r_temp5, r_temp5.w
	mul r_temp6.xyz, r_temp6, r_temp6.w
	
};


vertexfragment PointSpotLightVectorsZW&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp6.xyz, c_lightPositions[a0.x+2], r_temp8         // light vector generation
	sub r_temp7.xyz, c_lightPositions[a0.x+3], r_temp8

	dp3 r_range.z, r_temp6, r_temp6       // compute squared length of light vector
	dp3 r_range.w, r_temp7, r_temp7

	rsq r_temp6.w, r_range.z          // for normalization.
	rsq r_temp7.w, r_range.w

	// normalize light vectors.
	mul r_temp6.xyz, r_temp6, r_temp6.w
	mul r_temp7.xyz, r_temp7, r_temp7.w
	
};




vertexfragment PointSpotLightVectorsX&{versionString}= 
asm_fragment
{

	vs_&{versionString}

	sub r_temp4.xyz, c_lightPositions[a0.x], r_temp8         // light vector generation

	dp3 r_range.x, r_temp4, r_temp4       // compute squared length of light vector

	rsq r_temp4.w, r_range.x          // for normalization.

	// normalize light vectors.
	mul r_temp4.xyz, r_temp4, r_temp4.w
	
};



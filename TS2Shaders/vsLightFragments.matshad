asm_fragment
{
	vs_&{versionString}

	// coneAngle factor = 1.0 - (angle - outer) * 1/d

	sub r_temp1.z, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1.z, r_temp1, c_spotConeHelper2[a0.x]
	min r_temp1.z, r_temp1, c_basics.z  ; clamp to < 1.0
	max r_temp1.z, r_temp1, c_basics.x ; assure > 0
	

	mul r_attenuation.z, r_attenuation, r_temp1 // roll into attenuation.
};



vertexfragment SpotLightConesPart1W&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// find vector to light  dot light direction
	
	dp3 r_temp0.w, r_temp7, c_lightDirections[a0.x+3]
	
	// coneAngle factor = 1.0 - (angle - outer) * 1/d
};

vertexfragment SpotLightConesPart2W&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	sub r_temp1.w, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1.w, r_temp1, c_spotConeHelper2[a0.x]
	min r_temp1.w, r_temp1, c_basics.z  ; clamp to < 1.0
	max r_temp1.w, r_temp1, c_basics.x ; assure > 0
	

	mul r_attenuation.w, r_attenuation, r_temp1 // roll into attenuation.
};



vertexfragment PointSpotVisualizeAttenuationZ&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	mov r_diffuse_r2.rgb, r_attenuation.z
	
};

vertexfragment PointSpotVisualizeAttenuationZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	dp3 r_diffuse_r2.rgb, r_attenuation.zw, c_basics.zzxx
	

	// find vector to light  dot light direction
	
	dp3 r_temp0.z, r_temp6, c_lightDirections[a0.x+2]
	dp3 r_temp0.w, r_temp7, c_lightDirections[a0.x+3]

};


vertexfragment SpotLightConesPart2ZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}


	// coneAngle factor = 1.0 - (angle - outer) * 1/d

	sub r_temp1.zw, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1.zw, r_temp1, c_spotConeHelper2[a0.x]
	min r_temp1.zw, r_temp1, c_basics.z  // clamp to < 1.0
	max r_temp1.zw, r_temp1, c_basics.x // assure > 0

	mul r_attenuation.zw, r_attenuation, r_temp1 // roll into attenuation.
};



vertexfragment SpotLightConesPart1X&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// find vector to light  dot light direction
	
	dp3 r_temp0.x, r_temp4, c_lightDirections[a0.x]
};

vertexfragment SpotLightConesPart2X&{versionString}= 
asm_fragment
{
	// coneAngle factor = 1.0 - (angle - outer) * 1/d
	vs_&{versionString}
	

	sub r_temp1.x, r_temp0, c_spotConeHelper1[a0.x]  // (angle from spot center - outer Cone /2)

   mul r_temp1.x, r_temp1.x, c_spotConeHelper2[a0.x] // ( angle from inner cone - outer Cone /2)
  
   max r_temp1.x, r_temp1, c_basics.x // assure > 0
   min r_temp1.x, r_temp1, c_basics.z  // clamp to < 1.0

	mul r_attenuation.x, r_attenuation, r_temp1 // roll into attenuation.
};


vertexfragment SpotLightConesPart1Y&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// find vector to light  dot light direction
	
	dp3 r_temp0.y, r_temp5, c_lightDirections[a0.x+1]
	
	
};


vertexfragment SpotLightConesPart2Y&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// coneAngle factor = 1.0 - (angle - outer) * 1/d

	sub r_temp1.y, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1.y, r_temp1, c_spotConeHelper2[a0.x]

	min r_temp1.y, r_temp1, c_basics.z  ; clamp to < 1.0
	max r_temp1.y, r_temp1, c_basics.x ; assure > 0

	mul r_attenuation.y, r_attenuation, r_temp1 // roll into attenuation.
};




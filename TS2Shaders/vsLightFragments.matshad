	dp3 r_rdotls.x, c_lightDirections[a0.x], r_reflectionVector  // R.L light 1
	dp3 r_rdotls.y, c_lightDirections[a0.x+1], r_reflectionVector
	dp3 r_rdotls.z, c_lightDirections[a0.x+2], r_reflectionVector
	dp3 r_rdotls.w, c_lightDirections[a0.x+3], r_reflectionVector  // R.L light 4
	
};



// finish diffuse completely, and write it out.

vertexfragment CompleteDiffuseHDR&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	add r_diffuse_r2, c_ambientLightColor, r_diffuse_r2
	
	mul oT2.xyz, r_diffuse_r2, c_diffuseMaterialColor
	
};


// finish specular and emit.

vertexfragment CompleteSpecularHDR&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	mul oT3.xyz, r_specular_r2, c_specularMaterialColor

   
	
};


vertexfragment CompleteSpecular&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	mul oD1.xyz, r_specular_r2, c_specularMaterialColor
	
};

endShaderSource

enddef



define VS1UniqueLightingFragments()

##########
#   VS1  UNIQUE LIGHTING FRAGMENTS     #
##########

shaderSource

vertexfragment CreateReflectionVector1_1 = 
asm_fragment
{
	vs_1_1
	
	//INPUTS: Camera space position, camera space normal, r8, r9
	//OUTPUT: camera space reflection, r11
	//USES: r0, r1
	
	// create normalized view vector
	dp3 r_temp1.w, -r_temp8, -r_temp8
	rsq r_temp1.w, r_temp1.w
	mul r_temp1.xyz, -r_temp8, r_temp1.w
	
	// 2N
	add r_temp0.xyz, r_temp9, r_temp9   
	// N.V
	dp3 r_temp0.w, r_temp9, r_temp1
	
	// 2N ( N.V) - V
	mad r_reflectionVector.xyz, r_temp0, r_temp0.w, -r_temp1
		
};

vertexfragment SetLight0Offset1_1= 
asm_fragment
{
	vs_1_1	
	mov a0.x, c_basics.x
};


vertexfragment SetLight1Offset1_1= 
asm_fragment
{
	vs_1_1	
	
	mov a0.x, c_basics.z
};

vertexfragment SetLight2Offset1_1= 
asm_fragment
{
	vs_1_1
	mov a0.x, c_basics.w
};


vertexfragment SetLight3Offset1_1= 
asm_fragment
{
	vs_1_1	
	mov a0.x, c_helperConstant2.y
};

vertexfragment SetLight4Offset1_1= 
asm_fragment
{
	vs_1_1

	mov a0.x, c_helperConstant1.w
};





//#######
//#  SPECULAR (LOG/MUL/EXP  #
//#######


vertexfragment VertexSpecularXYZW1_1= 
asm_fragment
{
	vs_1_1
	
	add r_ndotls, r_ndotls, c_helperConstant2.w
   
	slt r_ndotlClamp, -r_ndotls, c_basics.x  // create booleans for N.L < 0
	slt r_temp2, -r_rdotls, c_basics.x  // create booleans for R.L < 0
	mul r_temp2, r_temp2, r_ndotlClamp // merge flags


	logp r_logexp.z, r_rdotls.xxxx
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.x  // cancel if R.L < 0 for light 1.
	mul r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x]  // complete specular for light 1

	logp r_logexp.z, r_rdotls.yyyy
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.y // cancel if R.L < 0 for light 2.
	mad r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x+1], r_specular_r2  // complete specular for light 1
	
	logp r_logexp.z, r_rdotls.zzzz
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.z // cancel if R.L < 0 for light 2.
	mad r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x+2], r_specular_r2  // complete specular for light 1

	logp r_logexp.z, r_rdotls.wwww
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.w // cancel if R.L < 0 for light 2.
	mad r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x+3], r_specular_r2  // complete specular for light 1
	
};


vertexfragment VertexSpecularXYZ1_1= 
asm_fragment
{
	vs_1_1
	
   add r_ndotls.xyz, r_ndotls, c_helperConstant2.w
	slt r_ndotlClamp.xyz, -r_ndotls, c_basics.x  // create booleans for N.L < 0
	slt r_temp2.xyz, -r_rdotls, c_basics.x  // create booleans for R.L < 0
	mul r_temp2.xyz, r_temp2, r_ndotlClamp // merge flags
	
	logp r_logexp.z, r_rdotls.xxxx
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.x  // cancel if R.L < 0 for light 1.
	mul r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x]  // complete specular for light 1

	logp r_logexp.z, r_rdotls.yyyy
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.y // cancel if R.L < 0 for light 2.
	mad r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x+1], r_specular_r2  // complete specular for light 1
	
	logp r_logexp.z, r_rdotls.zzzz
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp2.z // cancel if R.L < 0 for light 2.
	mad r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x+2], r_specular_r2  // complete specular for light 1

};



vertexfragment VertexSpecularXY1_1= 
asm_fragment
{
	vs_1_1
	
	// r_temp0 = inbound R.L set
	
	// use all the channels in r1 and save a temp.
   add r_ndotls.xy, r_ndotls, c_helperConstant2.w
	slt r_ndotlClamp.xyz, -r_ndotls, c_basics.x  // create booleans for N.L < 0
	slt r_temp2.zw, -r_rdotls, c_basics.x  // create booleans for R.L < 0
	mul r_temp2.zw, r_temp2, r_ndotlClamp // merge flags
		
	logp r_logexp.z, r_rdotls.xxxx
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp1.z  // cancel if R.L < 0 for light 1.
	mul r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x]  // complete specular for light 1
		

	logp r_logexp.z, r_rdotls.yyyy
	mul r_logexp.z, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp1.w // cancel if R.L < 0 for light 2.
	mad r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x+1], r_specular_r2  // complete specular for light 1

};


vertexfragment VertexSpecularX1_1= 
asm_fragment
{
	vs_1_1
	
   add r_ndotls.x, r_ndotls, c_helperConstant2.w
	slt r_ndotlClamp.x, -r_ndotls, c_basics.x  // create booleans for N.L < 0
	slt r_temp2.x, -r_rdotls, c_basics.x  // create booleans for R.L < 0
	mul r_temp2.x, r_temp2, r_ndotlClamp // merge flags
				
	logp r_logexp.z, r_rdotls.x
	
	mul r_temp1.x, r_logexp.z, c_specularMaterialColor.w // pow(x, shinyness)	for all 4 lights.
	
	expp r_logexp.z, r_logexp.z
	mul r_logexp.z, r_logexp.z, r_temp1.y

	mul r_specular_r2.rgb, r_logexp.z, c_lightColors[a0.x]  // complete specular for light 1
	
		
};



endShaderSource
enddef









define OffsetToMask( offset count)

	seti integerMask 15
	
	if (&offset = 1)
		if (&count > 2)
			seti integerMask 14
		endif
		
		if (&count = 2)
			seti integerMask 6
		endif
		
		if (&count = 1)
			seti integerMask 2
		endif
				
	endif

	if (&offset = 2)	
		if (&count > 1)
			seti integerMask 12
		endif
		
		if (&count = 1)
			seti integerMask 4
		endif

	endif

	if (&offset = 3)
		seti integerMask 8
	endif
	
	if (&offset = 0)
		if (&count > 3)
			seti integerMask 15
		endif

		if (&count = 3)
			seti integerMask 7
		endif
		
		if (&count = 2)
			seti integerMask 3
		endif
		
		if (&count = 1)
			seti integerMask 1
		endif
		
	endif
	
	if (&offset = 0 and &count = 0)
		seti integerMask 0
	endif
	
	
enddef


define GenerateMaskString( integerMask)


	if (&integerMask = 0)
		set returnedMaskString ""
	endif

	if (&integerMask = 1)
		set returnedMaskString X
	endif
	
	if (&integerMask = 2)
		set returnedMaskString Y
	endif

	if (&integerMask = 3)
		set returnedMaskString XY
	endif

	if (&integerMask = 4)
		set returnedMaskString Z
	endif

	if (&integerMask = 5)
		set returnedMaskString XZ
	endif

	if (&integerMask = 6)
		set returnedMaskString YZ
	endif

	if (&integerMask = 7)
		set returnedMaskString XYZ
	endif

	if (&integerMask = 8)
		set returnedMaskString W
	endif

	if (&integerMask = 9)
		set returnedMaskString XW
	endif

	if (&integerMask = 10)
		set returnedMaskString YW
	endif

	if (&integerMask = 11)
		set returnedMaskString XYW
	endif

	if (&integerMask = 12)
		set returnedMaskString ZW
	endif

	if (&integerMask = 13)
		set returnedMaskString XZW
	endif

	if (&integerMask = 14)
		set returnedMaskString YZW
	endif

	if (&integerMask = 15)
		set returnedMaskString XYZW
	endif

enddef


define DX8DiffusePassLightFragments(addAmbientFlag  bumpMapThisPass lightOffset lightCount distantLightCount pointLightCount spotLightCount shaderVersion)

	#trace "DX8 Diffuse lighting pass, ambient: &addAmbientFlag TotalCount: &lightCount, Distant: &distantLightCount, Point: &pointLightCount, Spot: &spotLightCount"
	
	set returnedMaskString ""
	seti integerMask 0


	#Should be diffuse material color

	seti spotOffset (&distantLightCount + &pointLightCount)
	seti pointSpotCount (&pointLightCount + &spotLightCount)

	seti distantVertexLightMask 0
	seti distantPixelLightMask 0

	seti pointSpotVertexLightMask 0
	seti pointSpotPixelLightMask 0

	seti finalVertexLightMask 0
	seti finalPixelLightMask 0
   
	setb secondSet false

	if (&lightOffset > 3)
		setb secondSet true
	endif

	create OffsetToMask( 0 &distantLightCount)
	seti distantMask $integerMask
	
	create OffsetToMask( &distantLightCount $pointSpotCount)
	seti pointSpotMask $integerMask
		
	create OffsetToMask($spotOffset &spotLightCount)
	seti spotMask $integerMask
	
	
	
	
	shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
	
###
# DX8 distant lights for this pass
###

	# bump map the first and 3rd light only. (sun and first point/spot light)

	if (&distantLightCount = 5)
		# a special case, since 5 distants light won't blow out the instruction count.
		shaderFragment DistantVertexDiffuseFiveLights&{shaderVersion}
	else
		create GenerateMaskString($distantMask)
		#trace "Distant light mask: $returnedMaskString"

		if (&distantLightCount)
			if (&bumpMapThisPass)

				# only bump the first (brightest) light, never light #2.
				if (&distantLightCount = 2 and $pointSpotCount = 0)
					seti distantVertexLightMask  2
					seti distantPixelLightMask 1
					seti perPixelLightCount 1
				else

					if (&distantLightCount > 1)
						seti distantVertexLightMask  ($distantMask - 1)
						seti distantPixelLightMask 1
						seti perPixelLightCount 1
                  
					else
					# rare case, only 1 distant light.
						seti distantVertexLightMask  0
						seti distantPixelLightMask 1
						seti perPixelLightCount 1
					endif	
					
				endif
						
			else
				seti distantVertexLightMask $distantMask
			endif
		endif
		
		
		if ($distantPixelLightMask)
			create GenerateMaskString($distantPixelLightMask)
			#trace "Distant PixeL LIght Mask: $returnedMaskString"
			shaderFragment PixelLightingDistantSetup${returnedMaskString}&{shaderVersion}
         seti finalPixelLightMask $distantPixelLightMask
		endif
		
				
		if ($distantVertexLightMask)
			create GenerateMaskString($distantVertexLightMask)
			
			#trace "Distant Vertex LIght Mask: $returnedMaskString"
			
			shaderFragment DistantVertexDiffuse${returnedMaskString}&{shaderVersion}
			
			seti finalVertexLightMask $distantVertexLightMask
		endif
		
	endif
	
	

####
# DX8 Point and spot for this pass
####

	#trace "final vertex mask so far: $finalVertexLightMask"
	if ($pointSpotCount)
	
		
		
		# create a 'bit list' of all pointspot lights.
		# full list  = Pixel Light List | Vertex Light List
		
		# 16 max,  4 min clocks.
		create GenerateMaskString($pointSpotMask)
		set pointSpotMaskString $returnedMaskString
		
		#trace "PointSpot Mask: $returnedMaskString"
		
		shaderFragment PointSpotLightVectors${pointSpotMaskString}&{shaderVersion}
		
		
		# 1 clock
		# set address register to '0' or '1' here
		if ($secondSet)
			shaderFragment SetLight1Offset&{shaderVersion}
		else
			shaderFragment SetLight0Offset&{shaderVersion}
		endif
		
		# 8 clocks max, 4 Minimum				
		shaderFragment PointSpotAttenuation${pointSpotMaskString}&{shaderVersion}


		# 10 clocks max, 7 minimum
		if (&spotLightCount)
			create GenerateMaskString($spotMask)

			# this fragment needs true light offset.
			shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
			shaderFragment SpotLightConesPart1${returnedMaskString}&{shaderVersion}

			#the next fragment needs 'high/low' offset.

			if ($secondSet)			
				shaderFragment SetLight1Offset&{shaderVersion}
			else
				shaderFragment SetLight0Offset&{shaderVersion}
			endif
				
			shaderFragment SpotLightConesPart2${returnedMaskString}&{shaderVersion}
		endif
			
		# at this point, diverge, and create point/spot tangent space vectors.
		if (&bumpMapThisPass)
		
			create OffsetToMask(&distantLightCount 1)
			seti pointSpotPixelLightMask $integerMask
			seti pointSpotVertexLightMask ($pointSpotMask - $integerMask)
			seti perPixelLightCount ($perPixelLightCount + 1)
		
		else
			seti pointSpotVertexLightMask ($pointSpotMask)
		endif
	
		# return the address register to it's original state and address lights.
		# 1 clock
		shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
		#trace "final vertex mask so far: $finalVertexLightMask"
		#trace "Point spot vertex mask: $pointSpotVertexLightMask"
		#trace "Point spot pixel mask: $pointSpotPixelLightMask"
		
		if ($pointSpotVertexLightMask)	
			# 5 max, 2 min
			create GenerateMaskString($pointSpotVertexLightMask)
			#trace "PointSpot vertex mask: $returnedMaskString"
			shaderFragment PointSpotVertexDiffuse${returnedMaskString}&{shaderVersion}
		endif
		
		if ($pointSpotPixelLightMask)
			create GenerateMaskString($pointSpotPixelLightMask)
			shaderFragment PixelLightingPointSpotSetup${returnedMaskString}&{shaderVersion}
			#trace "PointSpot pixel mask: $returnedMaskString"
			if (&distantLightCount = 0)
				shaderFragment WriteLightVectorToSpecular&{shaderVersion}
			else
				shaderFragment WriteLightVectorToTex3&{shaderVersion}
			endif
			
		endif
      seti finalPixelLightMask ($finalPixelLightMask + $pointSpotPixelLightMask)
		
		seti finalVertexLightMask ($finalVertexLightMask + $pointSpotVertexLightMask)
      
      #trace "final pixel mask $finalPixelLightMask"

	endif
	
	

####
# DX8 Finalize Diffuse here
####


	if (&distantLightCount < 5)

		if (&bumpMapThisPass)

			if ($finalVertexLightMask = 0) # all lights were bumpmapped.
				shaderFragment ZeroDiffuse&{shaderVersion} # zero r_diffuse_r2 so that the ambient can be added to it and the color finalized. 
			endif
		endif

		if ($finalVertexLightMask)
				
			create GenerateMaskString($finalVertexLightMask)
			#trace "Final vertex lighting mask: $returnedMaskString"
			shaderFragment VertexDiffuse${returnedMaskString}&{shaderVersion}
		endif

	endif
			

	if (&bumpMapThisPass)
		shaderFragment CompleteVertexDiffuseAddAmbientForPixelLighting&{shaderVersion}
	else

		if (&addAmbientFlag)
			shaderFragment CompleteVertexDiffuseAddAmbient&{shaderVersion}	
		else
			shaderFragment CompleteVertexDiffuse&{shaderVersion}	
		endif
	endif
	
		
enddef








define DX8SpecularPassLightFragments(lightOffset  lightCount distantLightCount pointLightCount spotLightCount shaderVersion)

	# ##trace "Specular lighting pass, TotalCount: &lightCount, Distant: &distantLightCount, Point: &pointLightCount, Spot: &spotLightCount"
	
	seti spotOffset (&distantLightCount + &pointLightCount)
	seti pointSpotCount (&pointLightCount + &spotLightCount)

	create OffsetToMask( &distantLightCount $pointSpotCount)
		
	set pointSpotMask $integerMask	
	
	create OffsetToMask($spotOffset &spotLightCount)
	set spotMask $integerMask
	
	shaderFragment CreateReflectionVector&{shaderVersion}
	
	shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
	
###
# DX8 specular distant lights for this pass
###

	if (&distantLightCount)
		create OffsetToMask(0 &distantLightCount)
		seti distantMask $integerMask
		
		create GenerateMaskString($distantMask)
		# ##trace "Distant light spec mask: $returnedMaskString"
		# I have to compute NdotL anyway, for shutting off R.L when N.L < 0
		shaderFragment DistantVertexDiffuse${returnedMaskString}&{shaderVersion} 
		shaderFragment DistantVertexSpecular${returnedMaskString}&{shaderVersion}
	else
		seti distantMask 0
	endif
	
	
	seti finalVertexSpecularMask $distantMask

####
# DX8 Specular Point and spot for this pass
####

	if ($pointSpotCount)
	
		# 16 to 4 clocks
		create GenerateMaskString($pointSpotMask)
		set pointSpotMaskString $returnedMaskString
		
		shaderFragment PointSpotLightVectors${pointSpotMaskString}&{shaderVersion}
		
		# set address register to '0' or '1' here, address 'pass'
		# 1 clock
		if ($secondSet)
			shaderFragment SetLight1Offset&{shaderVersion}
		else
			shaderFragment SetLight0Offset&{shaderVersion}
		endif
				
						
		shaderFragment PointSpotAttenuation${pointSpotMaskString}&{shaderVersion}


		if (&spotLightCount)   
			create GenerateMaskString($spotMask)

# address lights.			
			shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}

			shaderFragment SpotLightConesPart1${returnedMaskString}&{shaderVersion}
			
			# address light 'pass' offset.
			if ($secondSet)
				shaderFragment SetLight1Offset&{shaderVersion}
			else
				shaderFragment SetLight0Offset&{shaderVersion}
			endif

			shaderFragment SpotLightConesPart2${returnedMaskString}&{shaderVersion}

		endif
			
			
		# return the address register to it's original state and address lights.
		
		shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
		
		# compute the N.L so I can test for n.l < 0
		shaderFragment PointSpotVertexDiffuse${pointSpotMaskString}&{shaderVersion}
		
		# compute R.Ls for point/spot lights.
		shaderFragment PointSpotVertexSpecular${pointSpotMaskString}&{shaderVersion}
				
		# combine point/spot mask with distant mask to create final.
		seti finalVertexSpecularMask 	($finalVertexSpecularMask + $pointSpotMask)

	endif



####
# DX8 Finalize Specular here
####

	create GenerateMaskString($finalVertexSpecularMask)
	# ##trace "finalVertexSpecularMask : $returnedMaskString"

	shaderFragment VertexSpecular${returnedMaskString}&{shaderVersion}
	

# write output color  # 2 clocks
	shaderFragment CompleteVertexSpecular&{shaderVersion}	


enddef



define DX9LightFragments(addAmbientFlag  specularEnabled bumpMapThisSection lightOffset lightCount distantLightCount pointLightCount spotLightCount shaderVersion)
	
	
	#trace "$currentMaterialName"
	
	#trace "DX9 lighting chunk, Bumpmap: &bumpMapThisSection  ambient: &addAmbientFlag specular: &specularEnabled  light offset: &lightOffset TotalCount: &lightCount, Distant: &distantLightCount, Point: &pointLightCount, Spot: &spotLightCount"
	
	set returnedMaskString ""
	seti integerMask 0


	#Should be diffuse material color

	seti spotOffset (&distantLightCount + &pointLightCount)
	seti pointSpotCount (&pointLightCount + &spotLightCount)

	seti distantVertexLightMask 0
	seti distantPixelLightMask 0

	seti pointSpotVertexLightMask 0
	seti pointSpotPixelLightMask 0

	seti finalVertexLightMask 0
	
	setb secondSet false

	if (&lightOffset > 3)
		setb secondSet true
	endif

	create OffsetToMask( 0 &distantLightCount)
	seti distantMask $integerMask
	
	create OffsetToMask( &distantLightCount $pointSpotCount)
	seti pointSpotMask $integerMask
		
	create OffsetToMask($spotOffset &spotLightCount)
	seti spotMask $integerMask
	
	shaderFragment ZeroHDROutputs&{shaderVersion}
		
	shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
	
###
# DX9 distant lights for this call
###

	#trace "final vertex mask so far: $finalVertexLightMask"
	# bump map the first and 3rd light only. (sun and first point/spot light)

	create GenerateMaskString($distantMask)
	#trace "Distant light mask to string $distantMask : $returnedMaskString"

	if (&bumpMapThisSection)

		if (&distantLightCount > 1)
		
			# special 2 light case.
			if (&distantLightCount = 2 and &lightCount = 2)
				seti distantVertexLightMask  0
				seti distantPixelLightMask 3
				seti perPixelLightCount ($perPixelLightCount+2)
			endif
			
			# if there are exactly 2 distants, but still more lights, then bump the first  lights.
			
			if (&distantLightCount = 2 and &lightCount > 2)
				seti distantVertexLightMask  0
				seti distantPixelLightMask 3
				seti perPixelLightCount 2
			endif
			
			# probably the 5 light pie menu case, if this 'call' has 4 distants.
			# setup 3 pixel lights in this case, and 1 vertex.
			if (&distantLightCount > 2)
				create OffsetToMask(0 &distantLightCount)
				seti distantVertexLightMask $integerMask

				seti distantVertexLightMask  ($distantVertexLightMask - 7)
				
				seti distantPixelLightMask 7
				seti perPixelLightCount 3
			endif
			
		else
			# 1 or less distant lights..
			
			if ($distantLightCount = 0 )
				seti distantVertexLightMask  0
				seti distantPixelLightMask 0
				seti perPixelLightCount 0
			else
				seti distantVertexLightMask  0
				seti distantPixelLightMask 1
				seti perPixelLightCount 1
			endif
			
		endif	
					
	else
		seti distantVertexLightMask $distantMask
	endif



			
	if ($distantPixelLightMask)
		create GenerateMaskString($distantPixelLightMask)
		#trace "Distant PixeL LIght Mask: $returnedMaskString"
		shaderFragment PixelLightingDistantSetup${returnedMaskString}&{shaderVersion}
		
		if ($perPixelLightCount = 1)
			shaderFragment WriteLightVectorToTex4&{shaderVersion}
		endif
		
	endif
		
				
	if ($distantVertexLightMask)
		create GenerateMaskString($distantVertexLightMask)
		
		#trace "Distant Vertex LIght Mask: $returnedMaskString"
	
		shaderFragment DistantVertexDiffuse${returnedMaskString}&{shaderVersion}
			
		seti finalVertexLightMask $distantVertexLightMask
	endif
	
	

####
# DX9 Point and spot for this call
####

	#trace "final vertex mask so far: $finalVertexLightMask"
	if ($pointSpotCount)
			
		# create a 'bit list' of all pointspot lights.
		# full list  = Pixel Light List | Vertex Light List
		
		# 16 max,  4 min clocks.
		create GenerateMaskString($pointSpotMask)
		set pointSpotMaskString $returnedMaskString
		
		#trace "PointSpot Mask: $returnedMaskString"
		
		# a0.x must be the light index. (usually 0 or 4)
		shaderFragment PointSpotLightVectors${pointSpotMaskString}&{shaderVersion}
				
		# 1 clock
		# set address register to '0' or '1' here
		if ($secondSet)
			shaderFragment SetLight1Offset&{shaderVersion}
			#trace "light 1 offset"
		else
			shaderFragment SetLight0Offset&{shaderVersion}
			#trace "light 0 offset"
		endif
		
		# 8 clocks max, 4 Minimum		
		# this requires a 0 or 1 (1 = second bank of lights)		
		shaderFragment PointSpotAttenuation${pointSpotMaskString}&{shaderVersion}


		# 10 clocks max, 7 minimum
		if (&spotLightCount)
			create GenerateMaskString($spotMask)

			#trace "spot lights: &spotLightCount"
			 # true light offset.
			shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}

			#trace "SpotCone P1 - light offset: &lightOffset"
			# back to light offset, a 0 or 4.
			shaderFragment SpotLightConesPart1${returnedMaskString}&{shaderVersion}
			
			# set light to light block index.
			if ($secondSet)
				#trace "SpotCone P2 - light offset: 1"

				shaderFragment SetLight1Offset&{shaderVersion}
			else
				shaderFragment SetLight0Offset&{shaderVersion}
				#trace "SpotCone P2 - light offset: 0"
			endif
			
			# requires zero or one.
			
			shaderFragment SpotLightConesPart2${returnedMaskString}&{shaderVersion}

		
		endif
			
		# at this point, diverge, and create point/spot tangent space vectors.
		if (&bumpMapThisSection and $perPixelLightCount < 3)
		
		    # add another to the counter, so the PS is informed of the light count to expect.
			seti perPixelLightCount ($perPixelLightCount+1)
			create OffsetToMask(&distantLightCount 1)
			seti pointSpotPixelLightMask $integerMask
			seti pointSpotVertexLightMask ($pointSpotMask - $integerMask)
		
		else
			seti pointSpotVertexLightMask ($pointSpotMask)
		endif
	
		# return the address register to it's original state and address lights.
		# 1 clock
		shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
		#trace "final vertex mask so far: $finalVertexLightMask"
		#trace "Point spot vertex mask: $pointSpotVertexLightMask"
		#trace "Point spot pixel mask: $pointSpotPixelLightMask"
		
		if ($pointSpotVertexLightMask)	
			# 5 max, 2 min
			create GenerateMaskString($pointSpotVertexLightMask)
			#trace "PointSpot vertex mask: $returnedMaskString"
			shaderFragment PointSpotVertexDiffuse${returnedMaskString}&{shaderVersion}
		endif
		
		if ($pointSpotPixelLightMask)
			create GenerateMaskString($pointSpotPixelLightMask)
			# ##trace "PointSpot pixel mask: $returnedMaskString"
			shaderFragment PixelLightingPointSpotSetup${returnedMaskString}&{shaderVersion}

			if (&distantLightCount = 1)
				shaderFragment WriteLightVectorToTex5&{shaderVersion}
			endif
			
			if (&distantLightCount = 2)
				shaderFragment WriteLightVectorToTex6&{shaderVersion}
			endif
						
		endif
				
		seti finalVertexLightMask ($finalVertexLightMask + $pointSpotVertexLightMask)


	endif
	
	#trace "final vertex mask before finalize: $finalVertexLightMask"


####
# DX9 Finalize Diffuse here
####



	if (&bumpMapThisSection)
		if ($finalVertexLightMask = 0) # all lights were bumpmapped.
			shaderFragment ZeroDiffuse&{shaderVersion} # zero r_diffuse_r2 so that the ambient can be added to it and the color finalized. 
		endif
	endif

	if ($finalVertexLightMask)
		create GenerateMaskString($finalVertexLightMask)
		##trace "Final vertex lighting mask: $returnedMaskString"
		if ($secondSet)
			shaderFragment VertexDiffuseAccumulate${returnedMaskString}&{shaderVersion}
		else
			shaderFragment VertexDiffuse${returnedMaskString}&{shaderVersion}
		endif
		
	endif


# bumpmapping or not, only write the diffuse color out if the caller wants the ambient added (a signal to complete the diffuse)
	if (&addAmbientFlag)
		# if both are set, then this is a single 'chunk' case, no more lighting fragments follow
		shaderFragment CompleteVertexDiffuseAddAmbientHDR&{shaderVersion}
	endif


#####
# DX9 Specular code chunks
#####


	if (&specularEnabled)
		shaderFragment CreateReflectionVector&{shaderVersion}
	endif

	if (&specularEnabled)

		 #trace "Specular lighting pass, TotalCount: &lightCount, Distant: &distantLightCount, Point: &pointLightCount, Spot: &spotLightCount"
		
		shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
		
	###
	# distant lights for this call
	###

		if (&distantLightCount)
			create GenerateMaskString($distantMask)
			##trace "Distant light spec mask: $returnedMaskString"

			# recompute all lighting, just to be safe.
			if ($distantPixelLightMask)
				shaderFragment DistantVertexDiffuse${returnedMaskString}&{shaderVersion} 
			endif
			
			shaderFragment DistantVertexSpecular${returnedMaskString}&{shaderVersion}
		else
			seti distantMask 0
		endif
				
		seti finalVertexSpecularMask $distantMask

	####
	# Point and spot for this pass
	####

		if ($pointSpotCount)

			# compute N.Ls again, in case there were perpixel lights
			if ($pointSpotPixelLightMask)
				shaderFragment PointSpotVertexDiffuse${pointSpotMaskString}&{shaderVersion}
			endif

			# compute R.Ls for point/spot lights.
			shaderFragment PointSpotVertexSpecular${pointSpotMaskString}&{shaderVersion}
			
			# combine point/spot mask with distant mask to create final.
			seti finalVertexSpecularMask 	($finalVertexSpecularMask + $pointSpotMask)

		endif

		create GenerateMaskString($finalVertexSpecularMask)
		
		set finalSpecularMaskString $returnedMaskString
		
	####
	# Finalize Specular here
	####
	
		if ($secondSet = false)
			shaderFragment VertexSpecular${finalSpecularMaskString}&{shaderVersion}
		else
			shaderFragment VertexSpecularAccumulate${finalSpecularMaskString}&{shaderVersion}
		endif

		# if we are adding ambient, then this is the only  or 2nd calling of this function, complete specular now and write to output.
			
		if (&addAmbientFlag)
			shaderFragment CompleteSpecularHDR&{shaderVersion}
		endif
			
	endif # if specular
		


	#shaderFragment NoLightingHDR&{shaderVersion}
		
enddef




define CheckForSpecular()

	setb doSpecular false
	setf specIntensity 0.0
	
	
	if ($stdMatSpecPower > 1)
		setf  specIntensity ($stdMatSpecCoef.x + $stdMatSpecCoef.y + $stdMatSpecCoef.z)
		
		if ($specIntensity > 0.30)
			setb doSpecular true
		else
			##trace "Specular coef amazingly low, cancelling specular for this material: $currentMaterialName"
			seti stdMatSpecPower 0
		endif
		
	endif
	
enddef




define StandardLightFragmentsSWVS(specularFlag shaderVersion)


# DISTANT LIGHTS

	##trace "------------- $currentMaterialName -- StandardLightFragmentsSWVS, specular Flag: &specularFlag"

	seti totalLights ($distantLightCount + $pointLightCount +$spotLightCount)
	
	seti slotsLeft 4
	seti pass1DistantLights 0
	seti pass1PointLights 0
	seti pass1SpotLights 0
	seti pass1PointSpotLights 0 
	setb doSpecular false
	

	create CheckForSpecular()

	# 4 or less light case.
	
	if ($totalLights < 5)
		if ($totalLights > 0)
			create SWVSLightFragments( true $doSpecular 0 $totalLights $distantLightCount $pointLightCount $spotLightCount &shaderVersion)
			seti totalLights 0
		endif
	else
					
		if ($distantLightCount < 5)
			seti pass1DistantLights $distantLightCount
		else
			seti pass1DistantLights 4
		endif
				
		seti slotsLeft (4 - $pass1DistantLights)
		##trace "Slots left after distant: $slotsLeft"
					
		if ($pointLightCount > $slotsLeft)  # more point lights than slots left.
			seti pass1PointLights $slotsLeft   # pass 1 points then are the rest of the slots.
			seti slotsLeft 0  # no more slots left.
		else
			seti slotsLeft ($slotsLeft - $pointLightCount)  # there was room, compute new slots left
			seti pass1PointLights $pointLightCount  # consumes all point lights in the first pass.
		endif
					
		##trace "Slots left after point: $slotsLeft"

		if ($spotLightCount > $slotsLeft)  # more spot lights than slots left.
			seti pass1SpotLights $slotsLeft   # pass 1 points then are the rest of the slots.
			seti slotsLeft 0  # no more slots left.
		else
			seti slotsLeft ($slotsLeft - $spotLightCount)  # there was room, compute new slots left
			seti pass1SpotLights $spotLightCount  # consumes all point lights in the first pass.
		endif
			
		# start at light zero, no ambient yet, 4 lights...
		create SWVSLightFragments( false $doSpecular 0 4 $pass1DistantLights $pass1PointLights $pass1SpotLights &shaderVersion)

		seti pass2DistantLights ($distantLightCount - $pass1DistantLights)
		seti pass2PointLights ($pointLightCount - $pass1PointLights)
		seti pass2SpotLights ($spotLightCount - $pass1SpotLights)

		seti totalLightsLeft ($pass2DistantLights +  $pass2PointLights + $pass2SpotLights)
		
		if ($totalLights)
			create SWVSLightFragments( true $doSpecular 4 $totalLightsLeft $pass2DistantLights $pass2PointLights $pass2SpotLights &shaderVersion)
		endif			
		
	endif # one/two set of lights in this pass.
	
	
enddef



define SWVSLightFragments(addAmbientFlag  specularEnabled lightOffset lightCount distantLightCount pointLightCount spotLightCount shaderVersion)
	
	
	 ##trace "SWVS lighting chunk,  ambient: &addAmbientFlag specular: &specularEnabled  light offset: &lightOffset TotalCount: &lightCount, Distant: &distantLightCount, Point: &pointLightCount, Spot: &spotLightCount"
	
	set returnedMaskString ""
	seti integerMask 0


	#Should be diffuse material color

	seti spotOffset (&distantLightCount + &pointLightCount)
	seti pointSpotCount (&pointLightCount + &spotLightCount)

	seti distantVertexLightMask 0

	seti pointSpotVertexLightMask 0

	seti finalVertexLightMask 0
	
	setb secondSet false

	if (&lightOffset > 3)
		setb secondSet true
	endif

	create OffsetToMask( 0 &distantLightCount)
	seti distantMask $integerMask
	
	create OffsetToMask( &distantLightCount $pointSpotCount)
	seti pointSpotMask $integerMask
		
	create OffsetToMask($spotOffset &spotLightCount)
	seti spotMask $integerMask
	
	
	
	
	shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
	
###
#  distant lights for this call
###

	 ##trace "final vertex mask so far: $finalVertexLightMask"
	# bump map the first and 3rd light only. (sun and first point/spot light)

	create GenerateMaskString($distantMask)
	 ##trace "Distant light mask: $returnedMaskString"


	seti distantVertexLightMask $distantMask



			

				
	if ($distantVertexLightMask)
		create GenerateMaskString($distantVertexLightMask)
		
		# ##trace "Distant Vertex LIght Mask: $returnedMaskString"
	
		shaderFragment DistantVertexDiffuse${returnedMaskString}&{shaderVersion}
			
		seti finalVertexLightMask $distantVertexLightMask
	endif
	
	

####
# Point and spot for this call
####

	# ##trace "final vertex mask so far: $finalVertexLightMask"
	if ($pointSpotCount)
			
		# create a 'bit list' of all pointspot lights.
		# full list  = Pixel Light List | Vertex Light List
		
		# 16 max,  4 min clocks.
		create GenerateMaskString($pointSpotMask)
		set pointSpotMaskString $returnedMaskString
		
		# ##trace "PointSpot Mask: $returnedMaskString"
		
		shaderFragment PointSpotLightVectors${pointSpotMaskString}&{shaderVersion}
				
		# 1 clock
		# set address register to '0' or '1' here
		if ($secondSet)
			shaderFragment SetLight1Offset&{shaderVersion}
		else
			shaderFragment SetLight0Offset&{shaderVersion}
		endif
		
		# 8 clocks max, 4 Minimum				
		shaderFragment PointSpotAttenuation${pointSpotMaskString}&{shaderVersion}


		# 10 clocks max, 7 minimum
		if (&spotLightCount)
			create GenerateMaskString($spotMask)

			# set light index.			
			shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}

			shaderFragment SpotLightConesPart1${returnedMaskString}&{shaderVersion}
			
			# set light pass index
			if ($secondSet)
				shaderFragment SetLight1Offset&{shaderVersion}
			else
				shaderFragment SetLight0Offset&{shaderVersion}
			endif
			
			shaderFragment SpotLightConesPart2${returnedMaskString}&{shaderVersion}

		endif
			
		seti pointSpotVertexLightMask ($pointSpotMask)
	
		# return the address register to it's original state and address lights.
		# 1 clock
		shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
		# ##trace "final vertex mask so far: $finalVertexLightMask"
		# ##trace "Point spot vertex mask: $pointSpotVertexLightMask"
		# ##trace "Point spot pixel mask: $pointSpotPixelLightMask"
		
		if ($pointSpotVertexLightMask)	
			# 5 max, 2 min
			create GenerateMaskString($pointSpotVertexLightMask)
			# ##trace "PointSpot vertex mask: $returnedMaskString"
			shaderFragment PointSpotVertexDiffuse${returnedMaskString}&{shaderVersion}
		endif
			
		seti finalVertexLightMask ($finalVertexLightMask + $pointSpotVertexLightMask)


	endif
	
	

####
# Finalize Diffuse here
####


	if ($finalVertexLightMask)
		create GenerateMaskString($finalVertexLightMask)
		 ##trace "Final vertex lighting mask: $returnedMaskString"
		if ($secondSet)
			shaderFragment VertexDiffuseAccumulate${returnedMaskString}&{shaderVersion}
		else
			shaderFragment VertexDiffuse${returnedMaskString}&{shaderVersion}
		endif
		
	endif


# bumpmapping or not, only write the diffuse color out if the caller wants the ambient added (a signal to complete the diffuse)
	if (&addAmbientFlag)
		# if both are set, then this is a single 'chunk' case, no more lighting fragments follow
		shaderFragment CompleteVertexDiffuseAddAmbient&{shaderVersion}
	endif


#####
# Specular code chunks
#####


	if (&specularEnabled)
		shaderFragment CreateReflectionVector&{shaderVersion}
	endif

	if (&specularEnabled)

		 ##trace "Specular lighting pass, TotalCount: &lightCount, Distant: &distantLightCount, Point: &pointLightCount, Spot: &spotLightCount"
		
		shaderFragment SetLight&{lightOffset}Offset&{shaderVersion}
		
	###
	# distant lights for this call
	###

		if (&distantLightCount)
			create GenerateMaskString($distantMask)
			# ##trace "Distant light spec mask: $returnedMaskString"
			shaderFragment DistantVertexSpecular${returnedMaskString}&{shaderVersion}
		else
			seti distantMask 0
		endif
				
		seti finalVertexSpecularMask $distantMask

	####
	# Point and spot for this pass
	####

		if ($pointSpotCount)
		
			# compute R.Ls for point/spot lights.
			
			shaderFragment PointSpotVertexSpecular${pointSpotMaskString}&{shaderVersion}
					
			# combine point/spot mask with distant mask to create final.
			seti finalVertexSpecularMask 	($finalVertexSpecularMask + $pointSpotMask)

		endif

		create GenerateMaskString($finalVertexSpecularMask)
		
		set finalSpecularMaskString $returnedMaskString
		
	####
	# Finalize Specular here
	####
	
		if ($secondSet = false)
			shaderFragment VertexSpecular${finalSpecularMaskString}&{shaderVersion}
		else
			shaderFragment VertexSpecularAccumulate${finalSpecularMaskString}&{shaderVersion}
		endif

		# if we are adding ambient, then this is the only  or 2nd calling of this function, complete specular now and write to output.
			
		if (&addAmbientFlag)
			shaderFragment CompleteSpecular&{shaderVersion}
		endif
			
	endif # if specular
		


	
enddef



define BindsForLighting(lightingMode)

   #trace "$currentMaterialName"

	setv3 finalShaderDiffuse (($stdMatDiffCoef).xyz)
	setv3 finalShaderSpecular (($stdMatSpecCoef).xyz)
	setv3 finalShaderEmissive (($stdMatEmissiveCoef).xyz)

	setf adjustedSpecular ($stdMatSpecPower *0.4)
	
	if (&lightingMode = $kFullLighting)
		bindConstants 18 -bindingID allStandardLightData2 -constantCount 32


		# diffuse material color
		bindConstants 14 -bindingID immediateData -data ($finalShaderDiffuse, $stdMatAlphaMultiplier) -constantType float
		# specular material color
   		bindConstants 15 -bindingID immediateData -data ($finalShaderSpecular, $adjustedSpecular) -constantType float

		bindConstants 16 -bindingID ambientLight -constantCount 1 -constantType float

		bindConstants 17 -bindingID immediateData -data ($finalShaderEmissive, 1) -constantType float

	else
		if (&lightingMode = $kAmbientOnly)

			bindConstants 14 -bindingID immediateData -data ($finalShaderDiffuse, $stdMatAlphaMultiplier) -constantType float
			
			bindConstants 16 -bindingID ambientLight -constantCount 1 -constantType float

			bindConstants 17 -bindingID immediateData -data ($finalShaderEmissive, 1) -constantType float

		else
			bindConstants 14 -bindingID immediateData -data ($finalShaderDiffuse, $stdMatAlphaMultiplier) -constantType float
		endif
	endif
	

enddef


	vs_&{versionString}

	sub r_temp1.yz, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1.yz, r_temp1, c_spotConeHelper2[a0.x]
	min r_temp1.yz, r_temp1, c_basics.z  // clamp to < 1.0
	max r_temp1.yz, r_temp1, c_basics.x // assure > 0

	mul r_attenuation.yz, r_attenuation, r_temp1 // roll into attenuation.

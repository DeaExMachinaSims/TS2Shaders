	mad r_diffuse_r2.rgb, r_ndotls2.y, c_lightColors[a0.x+1], r_diffuse_r2
	mad r_diffuse_r2.rgb, r_ndotls2.z, c_lightColors[a0.x+2], r_diffuse_r2
};


vertexfragment CompleteVertexDiffuseAddAmbient&{versionString}=
asm_fragment
{	
	vs_&{versionString}

	add r_diffuse_r2.rgb, r_diffuse_r2, c_ambientLightColor
	mul r_diffuse_r2.rgb, r_diffuse_r2, c_diffuseMaterialColor
	
	add r_diffuse_r2.rgb, r_diffuse_r2, c_emissiveColor // not scaled by material color

	mul oD0.rgb, r_diffuse_r2, c_basics.y  // scale by 0.5.
	mov oD0.a, c_diffuseMaterialColor.w
	
};


vertexfragment CompleteVertexDiffuse&{versionString}=
asm_fragment
{	
	vs_&{versionString}

	mul r_diffuse_r2.rgb, r_diffuse_r2, c_diffuseMaterialColor

// emissive not added here, this fragment only added in two-pass lighting.

	mul oD0.rgb, r_diffuse_r2, c_basics.y // scale by 0.5.
	mov oD0.a, c_diffuseMaterialColor.w
};


vertexfragment CompleteVertexDiffuseHDR&{versionString}=
asm_fragment
{	
	vs_&{versionString}

	mul r_diffuse_r2.rgb, r_diffuse_r2, c_diffuseMaterialColor
	add r_diffuse_r2.rgb, r_diffuse_r2, c_emissiveColor // not scaled by material color

	mul oT2.rgb, r_diffuse_r2, c_basics.y // scale by 0.5.
	mov oT2.a, c_diffuseMaterialColor.w
};



vertexfragment CompleteVertexDiffuseAddAmbientForPixelLighting&{versionString}=
asm_fragment
{	
	vs_&{versionString}

	// don't apply material color here, since the PS will do this work.
	
	
	add r_diffuse_r2.rgb, r_diffuse_r2, c_ambientLightColor	// add ambient.
	add r_diffuse_r2.rgb, r_diffuse_r2, c_emissiveColor // have to add now, not enough instructions for PS1.1

	mul oD0.rgb, r_diffuse_r2, c_basics.y // scale by 0.5.
	mov oD0.a, c_diffuseMaterialColor.w

	
};



vertexfragment CompleteVertexDiffuseAddAmbientForPixelLightingHDR&{versionString}=
asm_fragment
{	
	vs_&{versionString}

	// don't apply material color here, since the PS will do this work.

	add r_diffuse_r2.rgb, r_diffuse_r2, c_emissiveColor // have to add now, not enough instructions for PS1.1

	add oT2.rgb, r_diffuse_r2, c_ambientLightColor	// add ambient.

	mov oT2.a, c_diffuseMaterialColor.w
	
};




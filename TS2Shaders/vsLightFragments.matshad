vertexfragment VertexDiffuseXYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	max r_ndotls2, c_basics.x, r_ndotls  // assure positive, but maintain unclamped ndotl for possible use in specular cutoff later
		
	mul r_diffuse_r2.rgb, r_ndotls2.x, c_lightColors[a0.x]
	mad r_diffuse_r2.rgb, r_ndotls2.y, c_lightColors[a0.x+1], r_diffuse_r2
	mad r_diffuse_r2.rgb, r_ndotls2.z, c_lightColors[a0.x+2], r_diffuse_r2
	mad r_diffuse_r2.rgb, r_ndotls2.w, c_lightColors[a0.x+3], r_diffuse_r2
	
};



vertexfragment SpotLightConesPart1XYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// find vector to light  dot light direction
	
	dp3 r_temp0.x, r_temp4, c_lightDirections[a0.x]
	dp3 r_temp0.y, r_temp5, c_lightDirections[a0.x+1]
	dp3 r_temp0.z, r_temp6, c_lightDirections[a0.x+2]
	dp3 r_temp0.w, r_temp7, c_lightDirections[a0.x+3]
};


vertexfragment SpotLightConesPart2XYZW&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// coneAngle factor = (angle - outer) * 1/d

	sub r_temp1, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1, r_temp1, c_spotConeHelper2[a0.x]
	min r_temp1, r_temp1, c_basics.z  // clamp to < 1.0
	max r_temp1, r_temp1, c_basics.x // assure > 0

	mul r_attenuation, r_attenuation, r_temp1 // roll into attenuation.
};


vertexfragment SpotLightConesPart1XYZ&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// find vector to light  dot light direction
	
	dp3 r_temp0.x, r_temp4, c_lightDirections[a0.x]
	dp3 r_temp0.y, r_temp5, c_lightDirections[a0.x+1]
	dp3 r_temp0.z, r_temp6, c_lightDirections[a0.x+2]
	
};

	
vertexfragment SpotLightConesPart2XYZ&{versionString}= 
asm_fragment
{
	vs_&{versionString}

	// coneAngle factor = 1.0 - (angle - outer) * 1/d

	sub r_temp1.xyz, r_temp0, c_spotConeHelper1[a0.x]
	mul r_temp1.xyz, r_temp1, c_spotConeHelper2[a0.x]
	min r_temp1.xyz, r_temp1, c_basics.z  // clamp to < 1.0
	max r_temp1.xyz, r_temp1, c_basics.x // assure > 0

	mul r_attenuation.xyz, r_attenuation, r_temp1 // roll into attenuation.
};





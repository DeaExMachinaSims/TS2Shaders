vertexfragment DistantVertexDiffuseFiveLights&{versionString}= 
asm_fragment
{
	vs_&{versionString}
	
	dp3 r_ndotls.x, c_lightDirections[a0.x], r_temp9  // N.L light 1
	dp3 r_ndotls.y, c_lightDirections[a0.x+1], r_temp9
	dp3 r_ndotls.z, c_lightDirections[a0.x+2], r_temp9  // N.L light 3
	dp3 r_ndotls.w, c_lightDirections[a0.x+3], r_temp9
	
	max r_ndotls, r_ndotls, c_basics.x
	
	dp3 r_temp1.x, c_lightDirections[a0.x+4], r_temp9  // N.L light 5

	max r_temp1.x, r_temp1.x, c_basics.x
	
	mul r_diffuse_r2.rgb, r_temp1.x, c_lightColors[a0.x+4]
	mad r_diffuse_r2.rgb, r_ndotls.x, c_lightColors[a0.x], r_diffuse_r2
	mad r_diffuse_r2.rgb, r_ndotls.y, c_lightColors[a0.x+1], r_diffuse_r2
	mad r_diffuse_r2.rgb, r_ndotls.z, c_lightColors[a0.x+2], r_diffuse_r2
	mad r_diffuse_r2.rgb, r_ndotls.w, c_lightColors[a0.x+3], r_diffuse_r2

};




